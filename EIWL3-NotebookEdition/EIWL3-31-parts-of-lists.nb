Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "How does one read ",
 Cell[BoxData[
  RowBox[{
   StyleBox["list", "CodeVariable"], "[", 
   RowBox[{"[", 
    StyleBox["n", "CodeVariable"], "]"}], "]"}]], "InlineCode"],
 " out loud?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Usually \[OpenCurlyDoubleQuote]",
 StyleBox["list",
  FontSlant->"Italic"],
 " part ",
 StyleBox["n",
  FontSlant->"Italic"],
 "\[CloseCurlyDoubleQuote] or \[OpenCurlyDoubleQuote]",
 StyleBox["list",
  FontSlant->"Italic"],
 " sub ",
 StyleBox["n",
  FontSlant->"Italic"],
 "\[CloseCurlyDoubleQuote]. The second form (with \[OpenCurlyDoubleQuote]sub\
\[CloseCurlyDoubleQuote] short for \[OpenCurlyDoubleQuote]subscript\
\[CloseCurlyDoubleQuote]) comes from thinking about math and extracting \
components of vectors. "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
What happens if one asks for a part of a list that doesn\[CloseCurlyQuote]t \
exist?\
\>", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
One gets a message, and the original computation is returned undone.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Can I just get the first position at which something appears in a list?\
\>", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Yes. Use ",
 ButtonBox["FirstPosition",
  BaseStyle->"Link"],
 ". "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["How can I insert a sequence of elements into a list?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "A convenient way is to replace one element with ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Splice",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"{", 
    RowBox[{
     StyleBox["x", "CodeVariable"], ",", 
     StyleBox["y", "CodeVariable"], ",", 
     StyleBox["...",
      FontColor->GrayLevel[0.6]]}], "}"}], "]"}]], "InlineCode"],
 ", which automatically \[OpenCurlyDoubleQuote]splices itself\
\[CloseCurlyDoubleQuote] in, so that for example ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"a", ",", "b", ",", 
    RowBox[{
     ButtonBox["Splice",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], "]"}], ",", "c"}], "}"}]], "InlineCode"],
 " gives ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"a", ",", "b", ",", "x", ",", "y", ",", "c"}], "}"}]], 
  "InlineCode"],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

