     RowBox[{
      RowBox[{"StringLength", "[", "#", "]"}], ">", "5"}], ",", "Nothing", 
     ",", 
     RowBox[{"StringReverse", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
  RowBox[{"RandomSample", "[", 
