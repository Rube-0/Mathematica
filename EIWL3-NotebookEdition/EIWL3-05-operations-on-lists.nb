Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Can one add lists of different lengths?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "No. ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}], 
   ButtonBox["+",
    BaseStyle->"Link",
    ButtonData->"Plus"], 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]], "InlineCode"],
 " won\[CloseCurlyQuote]t work. ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "0"}], "}"}], 
   ButtonBox["+",
    BaseStyle->"Link",
    ButtonData->"Plus"], 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]], "InlineCode"],
 " would be fine, if that\[CloseCurlyQuote]s what you mean."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Can there be a list with nothing in it?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Yes. ",
 Cell[BoxData[
  RowBox[{"{", "\[VeryThinSpace]", "}"}]], "InlineCode"],
 " is a list of length 0, with no elements. It\[CloseCurlyQuote]s usually \
called the ",
 StyleBox["null list",
  FontSlant->"Italic"],
 " or the ",
 StyleBox["empty list",
  FontSlant->"Italic"],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["IntegerDigits",
    BaseStyle->"CodeLink"], "[", "5671", "]"}]], "InlineCode"],
 " gives digits in base 10. ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["IntegerDigits",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"5671", ",", "2"}], "]"}]], "InlineCode"],
 " gives digits in base 2. You can use any base you want. ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["FromDigits",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"{", 
    RowBox[{"5", ",", "6", ",", "7", ",", "1"}], "}"}], "]"}]], 
  "InlineCode"],
 " reconstructs a number from its list of digits."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["Rest",
    BaseStyle->"CodeLink"], "[", 
   StyleBox["list", "CodeVariable"], "]"}]], "InlineCode"],
 " gives all the elements of ",
 Cell[BoxData[
  StyleBox["list", "CodeVariable"]], "InlineCode"],
 " after the first one. ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Most",
    BaseStyle->"CodeLink"], "[", 
   StyleBox["list", "CodeVariable"], "]"}]], "InlineCode"],
 " gives all elements other than the last one."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

