Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Why not always use ",
 Cell[BoxData[
  ButtonBox[":=",
   BaseStyle->"Link",
   ButtonData->"SetDelayed"]], "InlineCode"],
 "?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Because you don\[CloseCurlyQuote]t want to have to recompute things unless it\
\[CloseCurlyQuote]s necessary. It\[CloseCurlyQuote]s more efficient to just \
compute something once, then use the result over and over again.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "How does one read ",
 Cell[BoxData[
  ButtonBox[":=",
   BaseStyle->"Link",
   ButtonData->"SetDelayed"]], "InlineCode"],
 " and ",
 Cell[BoxData[
  ButtonBox[":>",
   BaseStyle->"Link",
   ButtonData->"RuleDelayed"]], "InlineCode"],
 " out loud?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox[":=",
   BaseStyle->"Link",
   ButtonData->"SetDelayed"]], "InlineCode"],
 " is usually just \[OpenCurlyDoubleQuote]colon \
equals\[CloseCurlyDoubleQuote], though sometimes \
\[OpenCurlyDoubleQuote]delayed assignment\[CloseCurlyDoubleQuote]. ",
 Cell[BoxData[
  ButtonBox[":>",
   BaseStyle->"Link",
   ButtonData->"RuleDelayed"]], "InlineCode"],
 " is usually \[OpenCurlyDoubleQuote]colon greater\[CloseCurlyDoubleQuote], \
though sometimes \[OpenCurlyDoubleQuote]delayed \
rule\[CloseCurlyDoubleQuote]."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "What happens if I do ",
 Cell[BoxData[
  RowBox[{"x", "=", 
   RowBox[{"x", "+", "1"}]}]], "InlineCode"],
 ", with ",
 Cell[BoxData["x"], "InlineCode"],
 " not having a value?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "You\[CloseCurlyQuote]ll start an infinite loop that\[CloseCurlyQuote]ll \
eventually get cut off by the system. ",
 Cell[BoxData[
  RowBox[{"x", "=", 
   RowBox[{"{", "x", "}"}]}]], "InlineCode"],
 " is the same story."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "What\[CloseCurlyQuote]s the significance of inputs being labeled ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["In",
     BaseStyle->"CodeLink"], "[", 
    StyleBox["n", "CodeVariable"], "]"}], 
   ButtonBox[":=",
    BaseStyle->"Link",
    ButtonData->"SetDelayed"]}]], "InlineCode"],
 ", and outputs ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["Out",
     BaseStyle->"CodeLink"], "[", 
    StyleBox["n", "CodeVariable"], "]"}], 
   ButtonBox["=",
    BaseStyle->"Link",
    ButtonData->"Set"]}]], "InlineCode"],
 " ?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "It indicates that inputs are assigned to ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["In",
    BaseStyle->"CodeLink"], "[", 
   StyleBox["n", "CodeVariable"], "]"}]], "InlineCode"],
 " and outputs to ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Out",
    BaseStyle->"CodeLink"], "[", 
   StyleBox["n", "CodeVariable"], "]"}]], "InlineCode"],
 ". The ",
 Cell[BoxData[
  ButtonBox[":=",
   BaseStyle->"Link",
   ButtonData->"SetDelayed"]], "InlineCode"],
 " for input means the assignment is delayed, so that if you ask for ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["In",
    BaseStyle->"CodeLink"], "[", 
   StyleBox["n", "CodeVariable"], "]"}]], "InlineCode"],
 " the result will be recomputed."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "In the Wolfram Language, the process of computing results is often called \
",
 StyleBox["evaluation",
  FontSlant->"Italic"],
 ", because it involves finding values of things."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "The Wolfram Language has many ways of controlling evaluation. An example is \
the function ",
 ButtonBox["Hold",
  BaseStyle->"Link"],
 ", which maintains an expression in \[OpenCurlyDoubleQuote]held\
\[CloseCurlyDoubleQuote] form until it is \[OpenCurlyDoubleQuote]released\
\[CloseCurlyDoubleQuote]."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "The internal form of ",
 Cell[BoxData[
  RowBox[{"x", 
   ButtonBox["=",
    BaseStyle->"Link",
    ButtonData->"Set"], "y"}]], "InlineCode"],
 " is ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Set",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"x", ",", "y"}], "]"}]], "InlineCode"],
 ". ",
 Cell[BoxData[
  RowBox[{"x", 
   ButtonBox[":=",
    BaseStyle->"Link",
    ButtonData->"SetDelayed"], "y"}]], "InlineCode"],
 " is ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["SetDelayed",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"x", ",", "y"}], "]"}]], "InlineCode"],
 ". ",
 Cell[BoxData[
  RowBox[{"x", 
   ButtonBox["\[RuleDelayed]",
    BaseStyle->"Link",
    ButtonData->"RuleDelayed"], "y"}]], "InlineCode"],
 " is ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["RuleDelayed",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"x", ",", "y"}], "]"}]], "InlineCode"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"LastCellOfAPage"]
}, Open  ]]
},
