Cell[TextData[{
 "It\[CloseCurlyQuote]s very common to use ",
 Cell[BoxData[
  ButtonBox[":=",
   BaseStyle->"Link",
   ButtonData->"SetDelayed"]], "InlineCodeText"],
 " if something isn\[CloseCurlyQuote]t ready yet when you\[CloseCurlyQuote]re \
defining a value."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

