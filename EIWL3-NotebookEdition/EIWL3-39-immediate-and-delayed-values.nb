 CellTags->"p: 253"],

Cell[TextData[{
 "There are two ways to assign a value to something in the Wolfram Language: ",
 StyleBox["immediate assignment",
  FontSlant->"Italic"],
 " (",
 Cell[BoxData[
  ButtonBox["=",
   BaseStyle->"Link",
   ButtonData->"Set"]], "InlineCodeText"],
 "), and ",
 StyleBox["delayed assignment",
  FontSlant->"Italic"],
 " (",
 Cell[BoxData[
  ButtonBox[":=",
   BaseStyle->"Link",
   ButtonData->"SetDelayed"]], "InlineCodeText"],
 ")."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
In immediate assignment, the value is computed immediately when the \
assignment is done, and is never recomputed. In delayed assignment, the \
computation of the value is delayed, and is done every time the value is \
requested.\
\>", "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "As a simple example, consider the difference between ",
 Cell[BoxData[
  RowBox[{"value", "=", 
   RowBox[{
    ButtonBox["RandomColor",
     BaseStyle->"CodeLink"], "[", "\[ThinSpace]", "]"}]}]], 
  "InlineCodeText"],
 " and ",
 Cell[BoxData[
  RowBox[{"value", ":=", 
   RowBox[{
    ButtonBox["RandomColor",
     BaseStyle->"CodeLink"], "[", "\[ThinSpace]", "]"}]}]], 
  "InlineCodeText"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

