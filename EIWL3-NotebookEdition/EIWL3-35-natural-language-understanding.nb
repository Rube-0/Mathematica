Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Total", "[", 
  RowBox[{"{", 
   RowBox[{
    TemplateBox[{
      InterpretationBox[
       TagBox[
        InterpretationBox[
         StyleBox["\"4.25\"", ShowStringCharacters -> False], 4.25, 
         AutoDelete -> True], 
        NumberForm[#, {Infinity, 2}, DigitBlock -> 3, NumberSeparator -> 
         "\[ThinSpace]"]& ], 4.25, Selectable -> False], 
