Cell[TextData[{
 ButtonBox["Interpreter",
  BaseStyle->"Link"],
 " converts natural language to Wolfram Language expressions that you can \
compute with. ",
 "Here\[CloseCurlyQuote]s an example",
 " involving currency amounts. "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"4d58d3e8-c61b-423f-bf82-c0e3ef14df70"],

Cell["Interpret various currency amounts:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"a13b5683-a973-4abc-82f5-0ff9b4c141fd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Interpreter", "[", "\"\<CurrencyAmount\>\"", "]"}], "[", 
  RowBox[{"{", 
   RowBox[{"\"\<4.25 dollars\>\"", ",", "\"\<85 cents\>\"", 
    ",", "\"\<3400 rupees\>\"", ",", "\"\<5 euros\>\""}], "}"}], 
  "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[4]:=",ExpressionUUID->"b9fb55ef-ef98-4d42-8f0e-4899601a5f61"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TemplateBox[{
     InterpretationBox[
      TagBox[
       InterpretationBox[
        StyleBox["\"4.25\"", ShowStringCharacters -> False], 4.25, AutoDelete -> 
        True], NumberForm[#, {Infinity, 2}, DigitBlock -> 3, NumberSeparator -> 
        "\[ThinSpace]"]& ], 4.25, Selectable -> False], 
     RowBox[{
       FormBox["\"$\"", TraditionalForm], "\[VeryThinSpace]"}], "US dollars", 
     "\"USDollars\""},
    "QuantityPrefix"], ",", 
   TemplateBox[{"85", 
     RowBox[{"\[VeryThinSpace]", 
       FormBox["\"\[Cent]\"", TraditionalForm]}], "US cents", "\"USCents\""},
    "QuantityPostfix"], ",", 
   TemplateBox[{"3400", 
     RowBox[{
       FormBox["\"\[Rupee]\"", TraditionalForm], "\[VeryThinSpace]"}], 
     "Indian rupees", "\"IndianRupees\""},
    "QuantityPrefix"], ",", 
   TemplateBox[{"5", 
     RowBox[{
       FormBox["\"\[Euro]\"", TraditionalForm], "\[VeryThinSpace]"}], "euros",
      "\"Euros\""},
    "QuantityPrefix"]}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[4]=",ExpressionUUID->"c00f3287-babb-4d26-b17b-67c8889eeea9"]
}, Open  ]],

Cell["\<\
Compute the total, doing conversions at current exchange rates:\
