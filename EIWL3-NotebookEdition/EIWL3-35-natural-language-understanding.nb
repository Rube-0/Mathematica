       "\"USDollars\""},
     "QuantityPrefix"], ",", 
    TemplateBox[{"85", 
      RowBox[{"\[VeryThinSpace]", 
        FormBox["\"\[Cent]\"", TraditionalForm]}], "US cents", "\"USCents\""},
     
     "QuantityPostfix"], ",", 
    TemplateBox[{"3400", 
      RowBox[{
        FormBox["\"\[Rupee]\"", TraditionalForm], "\[VeryThinSpace]"}], 
      "Indian rupees", "\"IndianRupees\""},
     "QuantityPrefix"], ",", 
    TemplateBox[{"5", 
      RowBox[{
        FormBox["\"\[Euro]\"", TraditionalForm], "\[VeryThinSpace]"}], 
      "euros", "\"Euros\""},
     "QuantityPrefix"]}], "}"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[5]:=",ExpressionUUID->"ea000d48-66a5-4337-a38b-4b1f8399e0df"],

