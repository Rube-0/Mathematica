Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["WordList",
    BaseStyle->"CodeLink"], "[", " ", "]"}]], "InlineCodeText",ExpressionUUID->
  "b86d0b9f-a530-40f3-9bd4-db73d9c516c9"],
 " gives a list of common words. ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["WordList",
    BaseStyle->"CodeLink"], "[", "\"\<Noun\>\"", "]"}]], "InlineCodeText",
  ExpressionUUID->"447a8fb9-3910-41e7-aac5-83b8d75ab32f"],
 ", etc. give lists of words that can be used as particular parts of speech. \
"
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 226",ExpressionUUID->"430f3c9b-249c-422e-ad03-affc79685a3b"],

