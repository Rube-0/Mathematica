Cell[TextData[{
 ButtonBox["Flatten",
  BaseStyle->"Link"],
 " will normally flatten out all levels of lists. But quite often you only \
want to flatten, say, one level of lists. This makes a 4\[Times]4 table ",
 "in which each element is itself",
 " a list."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

