Cell[TextData[{
 "If you don\[CloseCurlyQuote]t tell it otherwise, ",
 ButtonBox["Partition",
  BaseStyle->"Link"],
 " breaks a list up into non-overlapping blocks. But you can also tell it to \
break the list into blocks that have ",
 "some specified offset",
 ". "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

