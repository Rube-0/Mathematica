Cell[CellGroupData[{

Cell[TextData[{
 "Make 4 steps in the ",
 StyleBox["\[OpenCurlyDoubleQuote]Menger sponge\[CloseCurlyDoubleQuote]",
  FontSlant->"Italic"],
 " analog of the fractal Sierpinski pattern from the text, but with a \
\[OpenCurlyDoubleQuote]kernel\[CloseCurlyDoubleQuote] of the form ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      ButtonBox["#",
       BaseStyle->"Link",
       ButtonData->"Slot"], ",", 
      ButtonBox["#",
       BaseStyle->"Link",
       ButtonData->"Slot"], ",", 
      ButtonBox["#",
       BaseStyle->"Link",
       ButtonData->"Slot"]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      ButtonBox["#",
       BaseStyle->"Link",
       ButtonData->"Slot"], ",", "0", ",", 
      ButtonBox["#",
       BaseStyle->"Link",
       ButtonData->"Slot"]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      ButtonBox["#",
       BaseStyle->"Link",
       ButtonData->"Slot"], ",", 
      ButtonBox["#",
       BaseStyle->"Link",
       ButtonData->"Slot"], ",", 
      ButtonBox["#",
