Cell[CellGroupData[{

Cell[TextData[{
 "Find a simpler form for ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Join",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{
     ButtonBox["Join",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{
      RowBox[{
       ButtonBox["Range",
        BaseStyle->"CodeLink"], "[", "10", "]"}], ",", 
      RowBox[{
       ButtonBox["Reverse",
        BaseStyle->"CodeLink"], "[", 
       RowBox[{
        ButtonBox["Range",
         BaseStyle->"CodeLink"], "[", "10", "]"}], "]"}]}], "]"}], ",", 
    RowBox[{
     ButtonBox["Range",
      BaseStyle->"CodeLink"], "[", "10", "]"}]}], "]"}]], "InlineCode"],
 ".",
 StyleBox[ButtonBox["\[NonBreakingSpace]\[RightGuillemet]",
  Appearance->None,
  Evaluator->Automatic,
