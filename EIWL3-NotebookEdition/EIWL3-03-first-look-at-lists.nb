Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 PageBreakAbove->True],

Cell[TextData[{
 "How does one read ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "3"}], "}"}]], "InlineCode"],
 " out loud?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Usually \[OpenCurlyDoubleQuote]list 1 2 3\[CloseCurlyDoubleQuote]. \
\[OpenCurlyDoubleQuote]",
 Cell[BoxData["{"], "InlineCode"],
 "\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]",
 Cell[BoxData["}"], "InlineCode"],
 "\[CloseCurlyDoubleQuote] are called \[OpenCurlyDoubleQuote]braces\
\[CloseCurlyDoubleQuote] or \[OpenCurlyDoubleQuote]curly brackets\
\[CloseCurlyDoubleQuote]. \[OpenCurlyDoubleQuote]",
 Cell[BoxData["{"], "InlineCode"],
 "\[CloseCurlyDoubleQuote] is \[OpenCurlyDoubleQuote]open brace\
\[CloseCurlyDoubleQuote] and \[OpenCurlyDoubleQuote]",
 Cell[BoxData["}"], "InlineCode"],
 "\[CloseCurlyDoubleQuote] is \[OpenCurlyDoubleQuote]close brace\
\[CloseCurlyDoubleQuote]."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 FontTracking->-0.2],

Cell["Is a list a function?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 8}}],

Cell[TextData[{
 "Yes. ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "3"}], "}"}]], "InlineCode"],
 " is ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["List",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"1", ",", "2", ",", "3"}], "]"}]], "InlineCode"],
 ". But unlike, say, ",
 ButtonBox["Plus",
  BaseStyle->"Link"],
 ", the function ",
 ButtonBox["List",
  BaseStyle->"Link"],
 " doesn\[CloseCurlyQuote]t actually compute anything; it just comes back \
unchanged."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "What is ",
 ButtonBox["ListPlot",
  BaseStyle->"Link"],
 " plotting?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "The values of successive list elements. The ",
 StyleBox["x",
  FontSlant->"Italic"],
 " value of each point gives the position in the list; the ",
 StyleBox["y",
  FontSlant->"Italic"],
 " value gives the value of that element. "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["How long can lists be?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
As long as you want, until your computer runs out of memory. \
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["Range",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    StyleBox["m", "CodeVariable"], ",", 
    StyleBox["n", "CodeVariable"]}], "]"}]], "InlineCode"],
 " generates numbers from ",
 Cell[BoxData[
  StyleBox["m", "CodeVariable"]], "InlineCode"],
 " to ",
 Cell[BoxData[
  StyleBox["n", "CodeVariable"]], "InlineCode"],
 ". ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Range",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    StyleBox["m", "CodeVariable"], ",", 
    StyleBox["n", "CodeVariable"], ",", 
    StyleBox["s", "CodeVariable"]}], "]"}]], "InlineCode"],
 " generates numbers from ",
 Cell[BoxData[
  StyleBox["m", "CodeVariable"]], "InlineCode"],
 " to ",
 Cell[BoxData[
  StyleBox["n", "CodeVariable"]], "InlineCode"],
 " in steps of ",
 Cell[BoxData[
  StyleBox["s", "CodeVariable"]], "InlineCode"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Many computer languages have constructs like lists (often called \
\[OpenCurlyDoubleQuote]arrays\[CloseCurlyDoubleQuote]). But usually they only \
allow lists of explicit things, like numbers; you can\[CloseCurlyQuote]t have \
a list like ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"a", ",", "b", ",", "c"}], "}"}]], "InlineCode"],
 " where you haven\[CloseCurlyQuote]t said what ",
 Cell[BoxData["a"], "InlineCode"],
 ", ",
 Cell[BoxData["b"], "InlineCode"],
 " and ",
 Cell[BoxData["c"], "InlineCode"],
 " are. ",
 StyleBox["You can in the Wolfram Language, though, because the Wolfram \
Language",
  Background->None],
 " is ",
 StyleBox["symbolic",
  FontSlant->"Italic"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"a", ",", "b", ",", "c"}], "}"}]], "InlineCode"],
 " is a list of elements in a definite order; ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"b", ",", "c", ",", "a"}], "}"}]], "InlineCode"],
 " is a different list."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Like in math, you can make theorems about Wolfram Language functions. For \
example, ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Reverse",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    ButtonBox["Reverse",
     BaseStyle->"CodeLink"], "[", "x", "]"}], "]"}]], "InlineCode"],
 " is equal to ",
 Cell[BoxData["x"], "InlineCode"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

