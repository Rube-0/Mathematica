        FontFamily->"Source Sans Pro"]}]}], " ", ")"}], "/", "2"}], 
   StyleBox["&",
    FontFamily->"Source Sans Pro"]}]], "InlineCode"],
 " until the result no longer changes."
}], "Exercise",
