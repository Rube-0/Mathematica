Cell[TextData[{
 "Implement ",
 StyleBox["Euclid\[CloseCurlyQuote]s algorithm",
  FontSlant->"Italic"],
 " for GCD in which ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"a", ",", "b"}], "}"}]], "InlineCode"],
 " is repeatedly replaced by ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"b", ",", 
    RowBox[{
     StyleBox["Mod",
      FontFamily->"Source Sans Pro"], "[", 
     RowBox[{"a", ",", "b"}], "]"}]}], "}"}]], "InlineCode"],
 " until ",
 Cell[BoxData["b"], "InlineCode"],
 " is 0, and apply the algorithm to ",
 Cell[BoxData[
  RowBox[{"12345", ",", " ", "54321"}]], "InlineCode"],
 "."
}], "Exercise",
 Editable->False,
 Selectable->False,
 Deletable->False,
