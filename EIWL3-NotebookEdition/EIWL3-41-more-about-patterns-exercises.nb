Cell[TextData[{
 "Start from ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"0", ",", "0"}], "}"}]], "InlineCode"],
 " then for 200 steps repeatedly remove the first 2 elements, and append ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"2", ",", "1"}], "}"}]], "InlineCode"],
 " if the first element is ",
 Cell[BoxData["0"], "InlineCode"],
 ", ",
 Cell[BoxData[
  RowBox[{"{", "0", "}"}]], "InlineCode"],
 " if the first element is 1, and ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"0", ",", "2", ",", "1", ",", "2"}], "}"}]], "InlineCode"],
 " if it is ",
 Cell[BoxData["2"], "InlineCode"],
 ", and make a line plot of the lengths of the sequences produced (",
 StyleBox["tag system",
  FontSlant->"Italic"],
 ")."
}], "Exercise",
 Editable->False,
 Selectable->False,
 Deletable->False,
 CellDingbat->Cell[
  "41.12", "ExerciseNumber", FontColor -> 
   RGBColor[0.9019607843137255, 0.4117647058823529, 0.027450980392156862`]],
