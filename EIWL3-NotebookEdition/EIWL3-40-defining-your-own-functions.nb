Cell[TextData[{
 "How does this function definition work? The idea is that the ",
 Cell[BoxData[
  ButtonBox[":=",
   BaseStyle->"Link",
   ButtonData->"SetDelayed"]], "InlineCodeText"],
 " defines a value for the pattern ",
 Cell[BoxData[
  RowBox[{"pinks", "[", 
   StyleBox[
    RowBox[{
     StyleBox["n", "CodeVariable"], "_"}]], "]"}]], "InlineCodeText"],
 ". When you ask for ",
 Cell[BoxData[
  RowBox[{"pinks", "[", "5", "]"}]], "InlineCodeText"],
 ", this matches the ",
 Cell[BoxData[
  RowBox[{"pinks", "[", 
   StyleBox[
    RowBox[{
     StyleBox["n", "CodeVariable"], "_"}]], "]"}]], "InlineCodeText"],
 " pattern, and the value you\[CloseCurlyQuote]ve defined for this is used."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

