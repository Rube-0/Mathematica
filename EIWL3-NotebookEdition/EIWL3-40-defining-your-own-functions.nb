 CellLabel->"Out[12]="]
}, Open  ]],

Cell[TextData[{
 "Instead of having definitions for ",
 Cell[BoxData[
  RowBox[{"factorial", "[", "1", "]"}]], "InlineCodeText"],
 " and ",
 Cell[BoxData[
  RowBox[{"factorial", "[", 
   StyleBox[
    RowBox[{
     StyleBox["n", "CodeVariable"], "_"}]], "]"}]], "InlineCodeText"],
 " we could have had a single definition and used ",
 ButtonBox["If",
  BaseStyle->"Link"],
 ". But having separate definitions for each case tends to make things much \
easier to read and understand."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "An alternative definition using ",
 ButtonBox["If",
  BaseStyle->"Link"],
 ":"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[BoxData[
 RowBox[{
  RowBox[{"factorial", "[", "n_Integer", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"n", "\[Equal]", "1"}], ",", "1", ",", 
    RowBox[{"n", "*", 
     RowBox[{"factorial", "[", 
      RowBox[{"n", "-", "1"}], "]"}]}]}], "]"}]}]], "Input",
 Deletable->False,
 CellLabel->"In[13]:="],

Cell[TextData[{
 "It\[CloseCurlyQuote]s nice to be able to break out special cases, but the \
real power of being able to make definitions for anything comes when one goes \
beyond simple ",
 Cell[BoxData[
  RowBox[{
   StyleBox[" ", "CodeVariable"], 
   RowBox[{
    StyleBox["function", "CodeVariable"], "[", 
    StyleBox["argument", "CodeVariable"], "]"}]}]], "InlineCodeText"],
 " cases."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "As a simple example, consider making a definition for ",
 Cell[BoxData[
  RowBox[{"plusminus", "[", 
   RowBox[{"{", 
    RowBox[{"x_", ",", "y_"}], "}"}], "]"}]], "InlineCodeText"],
 ". "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Define a value for a pattern:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[BoxData[
 RowBox[{
  RowBox[{"plusminus", "[", 
   RowBox[{"{", 
    RowBox[{"x_", ",", "y_"}], "}"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"x", "+", "y"}], ",", 
    RowBox[{"x", "-", "y"}]}], "}"}]}]], "Input",
 Deletable->False,
 CellLabel->"In[14]:="],

