Cell[TextData[{
 "Clear definitions for ",
 Cell[BoxData["f"], "InlineCode"],
 " to make sure nothing gets confused later:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[BoxData[
 RowBox[{"Clear", "[", "f", "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[9]:="],

Cell[TextData[{
 "As another example, let\[CloseCurlyQuote]s do the classic computer science \
exercise of defining the ",
 Cell[BoxData["factorial"], "InlineCodeText"],
 " function. Start by saying that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"factorial", "[", "1", "]"}], "=", "1"}]], "InlineCodeText"],
 ". Then define how to compute ",
 Cell[BoxData[
  RowBox[{"factorial", "[", 
   StyleBox[
    RowBox[{
     StyleBox["n", "CodeVariable"], "_"}]], "]"}]], "InlineCodeText"],
 " recursively in terms of another instance of factorial."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Give a recursive definition of ",
 Cell[BoxData["factorial"], "InlineCode"],
 ":"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"factorial", "[", "1", "]"}], "=", "1"}], ";", " ", 
  RowBox[{
   RowBox[{"factorial", "[", "n_Integer", "]"}], ":=", 
   RowBox[{"n", "*", 
    RowBox[{"factorial", "[", 
     RowBox[{"n", "-", "1"}], "]"}]}]}]}]], "Input",
 Deletable->False,
 CellLabel->"In[10]:="],

Cell[TextData[{
 "Ask for ",
 Cell[BoxData[
  RowBox[{"factorial", "[", "50", "]"}]], "InlineCode"],
