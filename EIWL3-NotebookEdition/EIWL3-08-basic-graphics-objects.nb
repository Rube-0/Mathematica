Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["How can I make graphics with several objects?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["Section 14",
  BaseStyle->"Hyperlink",
  ButtonData->{
   "EIWL3-14-coordinates-and-graphics.nb", "graphics-with-several-objects"}],
 " will explain. To do so requires understanding ",
 StyleBox["coordinates",
  FontSlant->"Italic"],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Why use ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Circle",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 ", not just ",
 Cell[BoxData["Circle"], "InlineCode"],
 "?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "For consistency. As we\[CloseCurlyQuote]ll see in ",
 ButtonBox["Section 14",
  BaseStyle->"Hyperlink",
  ButtonData->{"EIWL3-14-coordinates-and-graphics.nb", "circle-x-y"}],
 ", ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Circle",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 " is actually short for ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Circle",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}], ",", "1"}], "]"}]], "InlineCode"],
 ", which means a circle of radius 1 and center coordinates ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"0", ",", "0"}], "}"}]], "InlineCode"],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Why isn\[CloseCurlyQuote]t the yellow dodecahedron pure yellow?", \
"Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Because the Wolfram Language displays it like an actual 3D object, with \
lighting. If it were pure yellow, it would be hard to see its 3D structure.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["What polyhedra can I use?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "The platonic solids ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Tetrahedron",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 ", ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Cube",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 ", ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Octahedron",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 ", ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Dodecahedron",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 ", ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Icosahedron",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 ", as well as ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["UniformPolyhedron",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"{", 
    StyleBox[
     RowBox[{"n", ",", "m"}], "CodeVariable"], "}"}], "]"}]], "InlineCode"],
 " (",
 Cell[BoxData[
  StyleBox["n", "CodeVariable"]], "InlineCode"],
 "-sided faces with ",
 Cell[BoxData[
  StyleBox["m", "CodeVariable"]], "InlineCode"],
 " faces at each vertex), and in general any polyhedron."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"LastCellOfAPage"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 34"],

Cell[TextData[{
 "Another way to specify styles for graphics is to give \
\[OpenCurlyDoubleQuote]directives\[CloseCurlyDoubleQuote] in a list, e.g. ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    ButtonBox["Yellow",
     BaseStyle->"CodeLink"], ",", 
    RowBox[{
     ButtonBox["Disk",
      BaseStyle->"CodeLink"], "[", "]"}], ",", 
    ButtonBox["Black",
     BaseStyle->"CodeLink"], ",", 
    RowBox[{
     ButtonBox["Circle",
      BaseStyle->"CodeLink"], "[", "]"}]}], "}"}]], "InlineCode"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Objects like ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Cube",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 " and ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Dodecahedron",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 " by default have unit side lengths; ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Sphere",
    BaseStyle->"CodeLink"], "[", "]"}]], "InlineCode"],
 " has unit radius."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

