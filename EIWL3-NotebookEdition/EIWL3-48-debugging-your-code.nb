Cell[TextData[{
 "Sometimes it\[CloseCurlyQuote]s not sufficient just to see the final result \
of a piece of code; you need to see what\[CloseCurlyQuote]s going on inside \
as well. You can insert the function ",
 ButtonBox["Echo",
  BaseStyle->"Link"],
 " anywhere to print intermediate results or values from your code."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"8426efe0-a906-44ef-9361-fd64f158f1ed"],

Cell[TextData[{
 ButtonBox["Echo",
  BaseStyle->"Link"],
 " prints values, but does not interfere with the result:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"575d523c-1335-4a36-8e31-9749e5dfb35e"],

