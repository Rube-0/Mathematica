Cell[BoxData[GridBox[{
   {
    RowBox[{
     ButtonBox["With",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        StyleBox["x", "CodeVariableLrg"], 
        ButtonBox["=",
         BaseStyle->"Link",
         ButtonData->"Set"], 
        StyleBox["value", "CodeVariableLrg"]}], "}"}], ",", 
      StyleBox["expr", "CodeVariableLrg"]}], "]"}], " ", Cell[TextData[{
     "compute ",
     Cell[BoxData[
      StyleBox["expr", "CodeVariable"]], "InlineCode",ExpressionUUID->
      "a7f543e9-0f97-4550-917d-324ab41b5095"],
     " with ",
     Cell[BoxData[
      StyleBox["x", "CodeVariable"]], "InlineCode",ExpressionUUID->
      "e9fa2f6d-031e-48c4-a00d-e6e5afc57348"],
     " replaced by ",
