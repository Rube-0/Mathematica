Cell[TextData[{
 ButtonBox["Echo",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["Monitor",
  BaseStyle->"Link"],
 " just display things. If you want to actually capture intermediate results, \
you can do it using ",
 ButtonBox["Sow",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["Reap",
  BaseStyle->"Link"],
 ". "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"9d1b3f65-3e10-4d51-ac03-7de71126c0ec"],

Cell[TextData[{
 ButtonBox["Reap",
  BaseStyle->"Link"],
 " gives the final result together with a list of everything that was sown by \
",
 ButtonBox["Sow",
  BaseStyle->"Link"],
 ":"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"3696aeaa-ec3a-41c1-8330-74c9819e186a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Reap", "[", 
  RowBox[{"Total", "[", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Sow", "[", "n", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "5"}], "}"}]}], "]"}], "]"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[10]:=",ExpressionUUID->"b5943662-6ef9-4406-b45c-d44e773d7716"],

Cell[BoxData[
 RowBox[{"{", 
