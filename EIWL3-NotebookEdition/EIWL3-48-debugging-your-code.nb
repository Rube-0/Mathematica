}, Open  ]],

Cell["\<\
Sometimes the Wolfram Language may not know what to do with something, but it \
may not be sure there\[CloseCurlyQuote]s a problem. In such cases, it\
\[CloseCurlyQuote]ll just leave the input unchanged and return it in a \
symbolic form that can later get a definite value.\
\>", "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"726b9b50-3189-456e-a933-d9acf31cd562"],

Cell[TextData[{
 "Without values for ",
 Cell[BoxData[
 "a"], "InlineCode",ExpressionUUID->"76f04925-2dd0-4c60-91f3-c321f4f5ee1b"],
 ", ",
 Cell[BoxData[
 "b"], "InlineCode",ExpressionUUID->"26f81e79-efcc-42ad-b1b2-2412d1bb975c"],
 " and ",
 Cell[BoxData[
 "c"], "InlineCode",ExpressionUUID->"4d3fbd7f-bf55-4976-bfde-aa53020b929a"],
 ", the Wolfram Language just returns this unchanged:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"91ed12b1-7b61-4676-86b3-ac1e2da246a5"],

