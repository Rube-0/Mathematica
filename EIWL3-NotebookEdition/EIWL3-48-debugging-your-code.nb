Cell[TextData[{
 "Use ",
 ButtonBox["Sow",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["Reap",
  BaseStyle->"Link"],
 " to find intermediate values of ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["#",
    BaseStyle->"Link",
    ButtonData->"Slot"], "1"}]], "InlineCode",ExpressionUUID->
  "80fb62c9-db24-4843-bfb1-4e72e8df92a5"],
 " in ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Fold",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{"10", 
     ButtonBox["#",
      BaseStyle->"Link",
      ButtonData->"Slot"], "1", 
     ButtonBox["+",
      BaseStyle->"Link",
      ButtonData->"Plus"], 
     ButtonBox["#",
      BaseStyle->"Link",
      ButtonData->"Slot"], "2", 
     ButtonBox["&",
      BaseStyle->"Link",
      ButtonData->"Function"]}], ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5"}], "}"}]}], "]"}]], 
  "InlineCode",ExpressionUUID->"e59ccb00-e78e-4c39-bb33-70b851d4834f"],
