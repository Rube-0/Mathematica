Cell[TextData[{
 "You can add data to this databin from all sorts of outside devices and \
services",
 "\[LongDash]",
 "as well as using the ",
 ButtonBox["DatabinAdd",
  BaseStyle->"Link"],
 " function in the Wolfram Language."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

