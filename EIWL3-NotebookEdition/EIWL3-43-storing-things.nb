Cell[TextData[{
 "Wolfram Data Drop, like ",
 ButtonBox["CloudPut",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["CloudSave",
  BaseStyle->"Link"],
 ", saves data into the cloud. But particularly if you\[CloseCurlyQuote]re \
not connected to the cloud, you may instead want to store things on a local \
computer. If you figure out where in your filesystem you want the files to \
go, you can use ",
 ButtonBox["Put",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Save",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["Get",
  BaseStyle->"Link"],
 " to store and retrieve them."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "It\[CloseCurlyQuote]s also possible to get the Wolfram Language to \
automatically figure out an \[OpenCurlyDoubleQuote]anonymous\
\[CloseCurlyDoubleQuote] local location. You can do this with ",
 ButtonBox["LocalObject",
  BaseStyle->"Link"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Generate an \[OpenCurlyDoubleQuote]anonymous\[CloseCurlyDoubleQuote] \
location for ",
 ButtonBox["Put",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Save",
  BaseStyle->"Link"],
 ", etc.:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LocalObject", "[", "\[ThinSpace]", "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[12]:="],

Cell[BoxData[
 RowBox[{"LocalObject", 
  "[", "\<\"file:///Users/sw/Library/Wolfram/Objects/365e034d-9830-4842-8681-\
75d3714b3d19\"\>", "]"}]], "Output",
 Editable->False,
 PageWidth->1000,
 CellEditDuplicate->False,
 Evaluatable->False,
 FontSize->14,
 CellLabel->"Out[12]="]
}, Open  ]],

