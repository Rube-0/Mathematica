Cell[CellGroupData[{

Cell["Vocabulary", "VocabularySection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 278"],

Cell[BoxData[GridBox[{
   {
    RowBox[{
     ButtonBox["CloudObject",
      BaseStyle->"CodeLink"], "[", "\[ThinSpace]", "]"}], " ", Cell[
    "create a cloud object", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["CloudPut",
      BaseStyle->"CodeLink"], "[", 
     StyleBox["expr", "CodeVariableLrg"], "]"}], " ", Cell[
    "put into the cloud", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["CloudGet",
      BaseStyle->"CodeLink"], "[", 
     StyleBox["obj", "CodeVariableLrg"], "]"}], " ", Cell[
    "get from the cloud ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["CloudSave",
      BaseStyle->"CodeLink"], "[", 
     StyleBox["s", "CodeVariableLrg"], "]"}], " ", Cell[
    "save definitions to the cloud", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["Databin",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"id\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["a databin with accumulated data", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["CreateDatabin",
      BaseStyle->"CodeLink"], "[", "\[ThinSpace]", "]"}], " ", Cell[
    "create a new databin", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["DatabinAdd",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{
      StyleBox["obj", "CodeVariableLrg"], ",", 
      StyleBox["value", "CodeVariableLrg"]}], "]"}], " ", Cell[
    "add something to a databin", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["DateListPlot",
      BaseStyle->"CodeLink"], "[", 
     StyleBox["data", "CodeVariableLrg"], "]"}], " ", Cell[
    "make a date list plot", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["LocalObject",
      BaseStyle->"CodeLink"], "[", "\[ThinSpace]", "]"}], " ", Cell[
    "create a local object", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["Put",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{
      StyleBox["expr", "CodeVariableLrg"], ",", 
      StyleBox["obj", "CodeVariableLrg"]}], "]"}], " ", Cell[
    "put into a local object", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["Get",
      BaseStyle->"CodeLink"], "[", 
     StyleBox["obj", "CodeVariableLrg"], "]"}], " ", Cell[
    "get from a local object", "VocabularyText"]}
  }]], "VocabularyTable",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 GridBoxOptions->{
 GridBoxDividers->{
  "Columns" -> {{False}}, "Rows" -> {False, {True, True, True, 
      Directive[
       Thickness[1.5], "VocabDivColor"], True, True, True, 
      Directive[
       Thickness[1.5], "VocabDivColor"], True, True, True}, False}}}]
}, Open  ]],

Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["What do the letters and numbers in UUIDs mean?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "They\[CloseCurlyQuote]re digits in hexadecimal (base 16); the letters \
\[OpenCurlyDoubleQuote]a\[CloseCurlyDoubleQuote] through \
\[OpenCurlyDoubleQuote]f\[CloseCurlyDoubleQuote] are the hex digits 10 \
through 15. Each UUID has 32 hex digits, corresponding to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"16", "^", "32"}], "\[TildeTilde]", 
    RowBox[{"3", "\[Times]", 
     SuperscriptBox["10", "38"]}]}], TraditionalForm]]],
 " possibilities."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
How does the number of possible UUIDs compare to other things?\
\>", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
It\[CloseCurlyQuote]s about the number of atoms in a cubic kilometer of \
water, or 100 trillion times the number of stars in the universe. If every \
one of 50 billion computers on Earth generated a UUID at 10 GHz, it\
\[CloseCurlyQuote]d take the age of the universe to run out of UUIDs.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["How do UUIDs relate to short IDs?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "All short IDs as generated by ",
 ButtonBox["URLShorten",
  BaseStyle->"Link"],
 " are explicitly registered, and guaranteed to be unique, a bit like domain \
names on the internet. UUIDs are long enough that they can be assumed to be \
unique, even without any kind of central registration."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Can I specify a file name in ",
 ButtonBox["CloudObject",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["CloudPut",
  BaseStyle->"Link"],
 ", etc.? "
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Yes. And the file name will be taken to be relative to your home directory in \
the cloud. The file will also get a URL, that includes the base of the cloud \
you\[CloseCurlyQuote]re using, and your user ID.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Can other people access what I store in a cloud object?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Not usually. But if you set the option ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Permissions",
    BaseStyle->"CodeLink"], 
   ButtonBox["\[Rule]",
    BaseStyle->"Link",
    ButtonData->"Rule"], "\"\<Public\>\""}]], "InlineCode"],
 " then everyone can access it, just like we discussed for web apps in ",
 ButtonBox["Section 36",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://www.wolfram.com/language/elementary-introduction/36-creating-\
websites-and-apps.html#i-3"], None},
  ButtonNote->
   "http://www.wolfram.com/language/elementary-introduction/36-creating-\
websites-and-apps.html#i-3"],
 ". ",
 "You can also define exactly who you want to allow to do what with it."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Can I work with databins without using the Wolfram Language?", \
"Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Yes. You can use the web and many other systems to create and add to databins.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"LastCellOfAPage"],

Cell["\<\
Is there a way to manipulate an expression in the cloud, without getting the \
whole expression?\
\>", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 279"],

Cell[TextData[{
 "Yes. Make it a cloud expression (using ",
 ButtonBox["CreateCloudExpression",
  BaseStyle->"Link"],
 "). Then all the usual ways of getting and setting parts of the expression \
will work, but the expression will be persistently stored in the cloud."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["How can I save function definitions?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "You can put them in a file using ",
 ButtonBox["Save",
  BaseStyle->"Link"],
 " or in the cloud using ",
 ButtonBox["CloudSave",
  BaseStyle->"Link"],
 ". You can also use ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["CreateNotebook",
    BaseStyle->"CodeLink"], "[", "\"\<FunctionResource\>\"", "]"}]], 
  "InlineCode"],
 " to create a definition notebook that lets you publish definitions so you \
or others can use them anywhere through ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["ResourceFunction",
    BaseStyle->"CodeLink"], "[", "...", "]"}]], "InlineCode"],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
When you work in the cloud, Wolfram Notebook documents are automatically \
stored after every change you make\[LongDash]unless you say not to do this.\
\>", "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "You can save large objects more efficiently with ",
 ButtonBox["DumpSave",
  BaseStyle->"Link"],
 " than ",
 ButtonBox["Save",
  BaseStyle->"Link"],
 ", but then the file you create is ",
 "binary, not",
 " text."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["LocalCache",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    ButtonBox["CloudObject",
     BaseStyle->"CodeLink"], "[", 
    StyleBox["...", "GrayPointSix"], "]"}], "]"}]], "InlineCode"],
 " is a way to refer to a cloud object, but to use a local cache of its \
contents if that\[CloseCurlyQuote]s available (and create it if it\
\[CloseCurlyQuote]s not). "
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Databins can have ",
 StyleBox["data signatures",
  FontSlant->"Italic"],
 ", that specify how data in them should be interpreted, for example in terms \
of units, date formats, etc."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "An assignment like ",
 Cell[BoxData[
  RowBox[{"x", "=", "3"}]], "InlineCode"],
 " lasts only for the duration of a Wolfram Language session. But you can use \
things like ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["PersistentSymbol",
     BaseStyle->"CodeLink"], "[", "\"\<x\>\"", "]"}], "=", "3"}]], 
  "InlineCode"],
 " to store values with different degrees of persistence (on a single \
computer; whenever you log in; for a certain time; etc.)"
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "The Resource System provides a centralized mechanism for publishing \
definitions for private or public use. Functions like ",
 ButtonBox["ResourceFunction",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["ResourceData",
  BaseStyle->"Link"],
 " let you access such definitions anywhere."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["More to Explore", "MoreExploreSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[ButtonBox["Guide to Files in the Wolfram Language\
\[NonBreakingSpace]\[RightGuillemet]",
 BaseStyle->"Link",
 ButtonData->"paclet:guide/FileOperations"]], "MoreExplore",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[ButtonBox["Wolfram Data \
Drop\[NonBreakingSpace]\[RightGuillemet]",
 BaseStyle->"Hyperlink",
 ButtonData->{
   URL["https://datadrop.wolframcloud.com/"], None},
 ButtonNote->"https://datadrop.wolframcloud.com/"]], "MoreExplore",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"LastCellOfAPage"]
}, Open  ]]
},
