Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["What named colors does the Wolfram Language have?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["Red",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Green",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Blue",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Black",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["White",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Gray",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Yellow",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Brown",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Orange",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Pink",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Purple",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["LightRed",
  BaseStyle->"Link"],
 ", etc. In ",
 ButtonBox["Section 16",
  BaseStyle->"Hyperlink",
  ButtonData->{"EIWL3-16-real-world-data.nb", None}],
 " we\[CloseCurlyQuote]ll see how to use ",
 Cell[BoxData[
  TemplateBox[{"ctrl", "="},
   "Key1"]]],
 " to enter any color name in plain English."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Why can colors be specified by red, green, blue values?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Basically because that\[CloseCurlyQuote]s how we humans perceive colors: \
there are three kinds of cells in our eyes that are roughly sensitive \
respectively to red, green and blue components of light. (Some other \
organisms work differently.) \
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["What does color negation do?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "It generates ",
 StyleBox["complementary colors",
  FontSlant->"Italic"],
 ", defined by computing 1\[Minus]",
 StyleBox["value",
  FontSlant->"Italic"],
 " (one minus the value) for each RGB component. If you negate the \
\[OpenCurlyDoubleQuote]display (emitted light) primaries\
\[CloseCurlyDoubleQuote] red, green, blue, you get the \
\[OpenCurlyDoubleQuote]print (reflected light) primaries\
\[CloseCurlyDoubleQuote] cyan, magenta, yellow."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["What is hue?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "It\[CloseCurlyQuote]s a way of specifying what are often called ",
 StyleBox["pure colors",
  FontSlant->"Italic"],
 ", independent of their tint, shade, saturation or brightness. Colors of \
different hues are often arranged around a ",
 StyleBox["color wheel",
  FontSlant->"Italic"],
 ". The RGB values for a particular hue are determined by a mathematical \
formula."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Are there other ways to specify colors than RGB?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Yes. A common one (implemented by ",
 ButtonBox["Hue",
  BaseStyle->"Link"],
 ") is to use the combination of hue, saturation and brightness. ",
 ButtonBox["LABColor",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["XYZColor",
  BaseStyle->"Link"],
 " are other examples. ",
 ButtonBox["GrayLevel",
  BaseStyle->"Link"],
 " represents shades of gray, with ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["GrayLevel",
    BaseStyle->"CodeLink"], "[", "0", "]"}]], "InlineCode"],
 " being black and ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["GrayLevel",
    BaseStyle->"CodeLink"], "[", "1", "]"}]], "InlineCode"],
 " being white."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "The little squares of color used to display a color are usually called ",
 StyleBox["swatches",
  FontSlant->"Italic"],
 ". Click a swatch in a notebook, and you\[CloseCurlyQuote]ll get an \
interactive color picker."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "You can specify named HTML colors by using for example ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["RGBColor",
    BaseStyle->"CodeLink"], "[", "\"\<maroon\>\"", "]"}]], "InlineCode"],
 ", as well as hex colors by using for example ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["RGBColor",
    BaseStyle->"CodeLink"], "[", "\"\<#00ff00\>\"", "]"}]], "InlineCode"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"LastCellOfAPage"],

Cell[TextData[{
 ButtonBox["ChromaticityPlot",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["ChromaticityPlot3D",
  BaseStyle->"Link"],
 " plot lists of colors in color space."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 29"],

Cell[TextData[{
 "You can set lots of other style attributes in the Wolfram Language, like ",
 ButtonBox["Bold",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Italic",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["FontFamily",
  BaseStyle->"Link"],
 ". "
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

