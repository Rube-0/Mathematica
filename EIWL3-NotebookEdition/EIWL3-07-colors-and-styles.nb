Cell[TextData[{
 "It\[CloseCurlyQuote]s often convenient to specify colors not directly in \
terms of red, green and blue, but for example instead in terms of ",
 StyleBox["hue",
  FontSlant->"Italic"],
 ". The function ",
 ButtonBox["Hue",
  BaseStyle->"Link"],
 " lets you do this. "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 26"],

