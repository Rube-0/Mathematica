   ",", "\<\"r\"\>", ",", "\<\"s\"\>"}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[11]="]
}, Open  ]],

Cell["\<\
Once you\[CloseCurlyQuote]ve broken a string into a list of characters, you \
can use all the usual list functions on it.\
\>", "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

