Cell[CellGroupData[{

Cell["Vocabulary", "VocabularySection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[BoxData[GridBox[{
   {"\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", " ", Cell[
    "a string ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["StringLength",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["length of a string ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["StringReverse",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["reverse a string ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["StringTake",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", ",", "4"}], 
     "]"}], " ", Cell[
    "take characters at the beginning of a string ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["StringJoin",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", ",", 
      "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\""}], "]"}], 
    " ", Cell["join strings together ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["StringJoin",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{"{", 
      RowBox[{
      "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", ",", 
       "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\""}], "}"}], 
     "]"}], " ", Cell["join a list of strings ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["ToUpperCase",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["convert characters to uppercase ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["Characters",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["convert a string to a list of characters ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["TextWords",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["list of words from a string ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["TextSentences",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["list of sentences ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["WikipediaData",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"topic\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["Wikipedia article about a topic ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["WordCloud",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"text\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["word cloud based on word frequencies ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["WordList",
      BaseStyle->"CodeLink"], "[", " ", "]"}], " ", Cell[
    "list of common words in English ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["Alphabet",
      BaseStyle->"CodeLink"], "[", "\[ThinSpace]", "]"}], " ", Cell[
    "list of letters of the alphabet ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["LetterNumber",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"c\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", Cell[
    "where a letter appears in the alphabet ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["FromLetterNumber",
      BaseStyle->"CodeLink"], "[", 
     StyleBox["n", "CodeVariableLrg"], "]"}], " ", Cell[
    "letter appearing at a position in the alphabet ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["Transliterate",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"text\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["transliterate text in any language into English", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["Transliterate",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{
     "\"\<\!\(\*StyleBox[\"text\", \"CodeVariableLrg\"]\)\>\"", ",", 
      "\"\<\!\(\*StyleBox[\"alphabet\", \"CodeVariableLrg\"]\)\>\""}], "]"}], 
    " ", Cell["transliterate text into other alphabets", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["RomanNumeral",
      BaseStyle->"CodeLink"], "[", 
     StyleBox["n", "CodeVariableLrg"], "]"}], " ", Cell[
    "convert a number to its Roman numeral string ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["IntegerName",
      BaseStyle->"CodeLink"], "[", 
     StyleBox["n", "CodeVariableLrg"], "]"}], " ", Cell[
    "convert a number to its English name string", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["InputForm",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["show a string with quotes ", "VocabularyText"]},
   {
    RowBox[{
     ButtonBox["Rasterize",
      BaseStyle->"CodeLink"], "[", 
     "\"\<\!\(\*StyleBox[\"string\", \"CodeVariableLrg\"]\)\>\"", "]"}], " ", 
    Cell["make a bitmap image ", "VocabularyText"]}
