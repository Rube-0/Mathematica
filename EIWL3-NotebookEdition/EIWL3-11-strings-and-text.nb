Cell[TextData[{
 "The invisible elements at the beginning of the list are space characters. \
If you want to see strings in the form you\[CloseCurlyQuote]d input them, \
complete with ",
 Cell[BoxData[
 "\"\<\!\(\*StyleBox[\"...\",FontColor->GrayLevel[0.6]]\)\>\""], 
  "InlineCodeText"],
 ", use ",
 ButtonBox["InputForm",
  BaseStyle->"Link"],
 ". "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["InputForm",
  BaseStyle->"Link"],
 " shows strings as you would input them, including quotes:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"InputForm", "[", 
  RowBox[{"Sort", "[", 
