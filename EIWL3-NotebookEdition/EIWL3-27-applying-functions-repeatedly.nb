Cell[TextData[{
 "With ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"2", "#"}], ",", " ", 
     RowBox[{
      RowBox[{"2", "#"}], "+", "1"}]}], "}"}], "&"}]], "InlineCodeText"],
 ", it works out that you\[CloseCurlyQuote]re always generating different \
numbers. But with ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"2", "#"}], ",", 
     RowBox[{"#", "+", "1"}]}], "}"}], "&"}]], "InlineCodeText"],
 ", you sometimes end up generating the same number in different ways. For \
example, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"2", "#"}], "&"}]], "InlineCodeText"],
 " applied to 2 gives 4. ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"#", "+", "1"}], "&"}]], "InlineCodeText"],
 " applied to 2 gives 3. But applying ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"#", "+", "1"}], "&"}]], "InlineCodeText"],
 " to 3 again gives 4. So this means there are two ways to get to 4, as \
represented by two \[OpenCurlyDoubleQuote]branches\[CloseCurlyDoubleQuote] \
merging at 4 in the graph generated by ",
 ButtonBox["NestGraph",
  BaseStyle->"Link"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Let\[CloseCurlyQuote]s say our function takes any country and gives a list of \
countries that border it. Starting from Switzerland, here\[CloseCurlyQuote]s \
the graph we get after one step, in effect showing the immediate neighbors of \
Switzerland. \
\>", "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
One step in generating a graph of bordering countries around Switzerland:\
\>", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NestGraph", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"#", "[", "\"\<BorderingCountries\>\"", "]"}], "&"}], ",", 
   NamespaceBox["LinguisticAssistant",
    DynamicModuleBox[{Typeset`query$$ = "switzerland", Typeset`boxes$$ = 
     TemplateBox[{"\"Switzerland\"", 
       RowBox[{"Entity", "[", 
         RowBox[{"\"Country\"", ",", "\"Switzerland\""}], "]"}], 
       "\"Entity[\\\"Country\\\", \\\"Switzerland\\\"]\"", "\"country\""}, 
      "Entity"], 
     Typeset`allassumptions$$ = {{
      "type" -> "Clash", "word" -> "switzerland", "template" -> 
       "Assuming \"${word}\" is ${desc1}. Use as ${desc2} instead", "count" -> 
       "2", "Values" -> {{
         "name" -> "Country", "desc" -> "a country", "input" -> 
          "*C.switzerland-_*Country-"}, {
