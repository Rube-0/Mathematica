  RowBox[{"{", "1", "}"}]], "InlineCode"],
 " and nestedly joining ",
 Cell[BoxData[
  RowBox[{"{", "0", "}"}]], "InlineCode"],
 " at the beginning and at the end, and adding these results together modulo \
2.",
