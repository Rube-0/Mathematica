      StyleBox["f", "CodeVariableLrg"], ",", 
      StyleBox["x", "CodeVariableLrg"], ",", 
      StyleBox["n", "CodeVariableLrg"]}], "]"}], " ", Cell[TextData[{
     "give the result of applying ",
     Cell[BoxData[
      StyleBox[
       RowBox[{" ", "f"}], "CodeVariable"]], "InlineCode"],
     " to ",
     Cell[BoxData[
      StyleBox["x", "CodeVariable"]], "InlineCode"],
     " exactly ",
     Cell[BoxData[
      StyleBox["n", "CodeVariable"]], "InlineCode"],
     " times "
    }], "VocabularyText"]},
   {
    RowBox[{
