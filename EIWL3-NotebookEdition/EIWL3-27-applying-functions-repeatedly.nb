Cell[CellGroupData[{
Cell[BoxData[
 InterpretationBox[Cell["Applying Functions Repeatedly", "SectionInline"],
  $Line = 0; Null]], "SectionDoubleDigit",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CounterAssignments->{{"Section", 26}, {"Subsection", 0}, {
   "Subsubsection", 0}, {"Exercise", 0}},
 CellTags->"p: 165"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"f", "[", "x", "]"}]], "InlineCodeText"],
 " applies ",
 Cell[BoxData["f"], "InlineCodeText"],
 " to ",
 Cell[BoxData["x"], "InlineCodeText"],
 ". ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"f", "[", "x", "]"}], "]"}]], "InlineCodeText"],
 " applies ",
 Cell[BoxData["f"], "InlineCodeText"],
 " to ",
 Cell[BoxData[
  RowBox[{"f", "[", "x", "]"}]], "InlineCodeText"],
 ", or effectively nests the application of ",
 Cell[BoxData["f"], "InlineCodeText"],
 ". It\[CloseCurlyQuote]s common to want to repeat or nest a function. "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "This makes a list of the results of nesting ",
 Cell[BoxData["f"], "InlineCode"],
 " up to 4 times:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NestList", "[", 
  RowBox[{"f", ",", "x", ",", "4"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[1]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"x", ",", 
   RowBox[{"f", "[", "x", "]"}], ",", 
   RowBox[{"f", "[", 
    RowBox[{"f", "[", "x", "]"}], "]"}], ",", 
   RowBox[{"f", "[", 
    RowBox[{"f", "[", 
     RowBox[{"f", "[", "x", "]"}], "]"}], "]"}], ",", 
   RowBox[{"f", "[", 
    RowBox[{"f", "[", 
     RowBox[{"f", "[", 
      RowBox[{"f", "[", "x", "]"}], "]"}], "]"}], "]"}]}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[1]="]
}, Open  ]],

Cell[TextData[{
 "Using ",
