Cell[TextData[{
 "If you want to see a list of the results of successive nestings, ",
 "use",
 " ",
 ButtonBox["NestList",
  BaseStyle->"Link"],
 ". If you only want to see the final result, use ",
 ButtonBox["Nest",
  BaseStyle->"Link"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["This gives the final result of 5 levels of nesting:", "CodeCaption",
