Cell[CellGroupData[{

Cell[TextData[{
 "Generate a graph by starting from 0, then nestedly 10 times connecting each \
node with value ",
 Cell[BoxData["n"], "InlineCode"],
 " to ones with values ",
 Cell[BoxData[
  RowBox[{"n", "+", "1"}]], "InlineCode"],
 " and ",
 Cell[BoxData[
  RowBox[{"2", "n"}]], "InlineCode"],
 ".",
 StyleBox[ButtonBox["\[NonBreakingSpace]\[RightGuillemet]",
  Appearance->None,
  Evaluator->Automatic,
  Method->"Preemptive",
  ButtonFunction:>(SelectionMove[
     ButtonNotebook[], All, ButtonCell, AutoScroll -> False]; 
   FrontEndExecute[
     FrontEndToken[
      ButtonNotebook[], "OpenCloseGroup"]])],
  FontColor->RGBColor[1, 0.501961, 0]]
