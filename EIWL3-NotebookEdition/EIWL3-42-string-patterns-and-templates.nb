Cell[TextData[{
 "String patterns work very much like other patterns in the Wolfram Language, \
except that they operate on sequences of characters in strings rather than \
parts of expressions. In a string pattern, you can combine pattern constructs \
like ",
 Cell[BoxData[
  ButtonBox["_",
   BaseStyle->"Link",
   ButtonData->"Blank"]], "InlineCodeText"],
 " with strings like ",
 Cell[BoxData["\"\<abc\>\""], "InlineCodeText"],
 " using ",
 Cell[BoxData[
  ButtonBox["~~",
   BaseStyle->"Link",
   ButtonData->"StringExpression"]], "InlineCodeText"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "This picks out all instances of ",
 Cell[BoxData["+"], "InlineCode"],
 " followed by a single character:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"StringCases", "[", 
  RowBox[{"\"\<+string +patterns are +quite +easy\>\"", ",", " ", 
   RowBox[{"\"\<+\>\"", "~~", "_"}]}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[1]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"+s\"\>", ",", "\<\"+p\"\>", ",", "\<\"+q\"\>", 
   ",", "\<\"+e\"\>"}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[1]="]
}, Open  ]],

Cell[TextData[{
 "This picks out three characters after each ",
 Cell[BoxData["+"], "InlineCode"],
 ":"
}], "CodeCaption",
