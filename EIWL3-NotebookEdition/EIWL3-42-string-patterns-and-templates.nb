 Evaluatable->False,
 CellLabel->"Out[15]="]
}, Open  ]],

Cell[TextData[{
 "Within strings, there\[CloseCurlyQuote]s a special newline character which \
indicates where the string should break onto a new line. The newline \
character is represented within strings as ",
 Cell[BoxData["\\n"], "InlineCodeText"],
 ". "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Split at newlines:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"StringSplit", "[", 
  RowBox[{"\"\<first line\nsecond line\nthird line\>\"", ",", "\"\<\\n\>\""}],
   "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[16]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"first line\"\>", ",", "\<\"second line\"\>", 
   ",", "\<\"third line\"\>"}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[16]="]
}, Open  ]],

Cell[TextData[{
 ButtonBox["StringJoin",
  BaseStyle->"Link"],
 " joins any list of strings together. In practice, though, one often wants \
to insert something between the strings before joining them. ",
 ButtonBox["StringRiffle",
  BaseStyle->"Link"],
 " does this."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Join strings, riffling the string ",
 Cell[BoxData["\"\<---\>\""], "InlineCode"],
 " in between them:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 ShowSyntaxStyles->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"StringRiffle", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "\"\<a\>\"", ",", "\"\<list\>\"", ",", "\"\<of\>\"", ",", 
     "\"\<strings\>\""}], "}"}], ",", "\"\<---\>\""}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[17]:="],

Cell[BoxData["\<\"a---list---of---strings\"\>"], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellTags->"LastCellOfAPage",
 CellLabel->"Out[17]="]
}, Open  ]],

Cell[TextData[{
 "In assembling strings, one often wants to turn arbitrary Wolfram Language \
expressions into strings. One can do this using ",
 ButtonBox["TextString",
  BaseStyle->"Link"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 272"],

Cell[TextData[{
 ButtonBox["TextString",
  BaseStyle->"Link"],
 " turns numbers and other Wolfram Language expressions into strings:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"StringJoin", "[", 
  RowBox[{"\"\<two to the \>\"", ",", 
   RowBox[{"TextString", "[", "50", "]"}], ",", "\"\< is \>\"", ",", 
   RowBox[{"TextString", "[", 
    RowBox[{"2", "^", "50"}], "]"}]}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[18]:="],

Cell[BoxData["\<\"two to the 50 is 1125899906842624\"\>"], "Output",
