 Evaluatable->False,
 CellLabel->"Out[8]="]
}, Open  ]],

Cell[TextData[{
 "Use ",
 ButtonBox["NestList",
  BaseStyle->"Link"],
 " to apply a string replacement repeatedly:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NestList", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"StringReplace", "[", 
     RowBox[{"#", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\"\<A\>\"", "\[Rule]", "\"\<AB\>\""}], ",", 
        RowBox[{"\"\<B\>\"", "\[Rule]", "\"\<BA\>\""}]}], "}"}]}], "]"}], 
