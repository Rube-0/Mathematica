 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[7]="]
}, Open  ]],

Cell[TextData[{
 "Make replacements for patterns, using ",
 Cell[BoxData[
  ButtonBox["\[RuleDelayed]",
   BaseStyle->"Link",
   ButtonData->"RuleDelayed"]], "InlineCode"],
 " to compute ",
 ButtonBox["ToUpperCase",
  BaseStyle->"Link"],
 " in each case:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"StringReplace", "[", 
  RowBox[{"\"\<now [several] important [words]\>\"", ",", " ", 
   RowBox[{
    RowBox[{"\"\<[\>\"", "~~", 
     RowBox[{"Shortest", "[", "x__", "]"}], "~~", "\"\<]\>\""}], 
