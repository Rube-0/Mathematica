Cell["Find the date of the Apollo 11 moon landing:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DateObject", "[", 
  TemplateBox[<|"query" -> "apollo 11 landing", "boxes" -> RowBox[{
       TemplateBox[{"\"Apollo 11\"", 
         RowBox[{"Entity", "[", 
           RowBox[{"\"MannedSpaceMission\"", ",", "\"Apollo11\""}], "]"}], 
         "\"Entity[\\\"MannedSpaceMission\\\", \\\"Apollo11\\\"]\"", 
         "\"manned space mission\""}, "Entity"], "[", 
       TemplateBox[{"\"lunar landing date\"", 
         RowBox[{"EntityProperty", "[", 
           RowBox[{"\"MannedSpaceMission\"", ",", "\"LunarLandingDate\""}], 
           "]"}], "\"EntityProperty[\\\"MannedSpaceMission\\\", \
\\\"LunarLandingDate\\\"]\""}, "EntityProperty"], "]"}], 
    "allassumptions" -> {{
      "type" -> "SubCategory", "word" -> "landing", "template" -> 
       "Assuming lunar landing date${separator}Use ${desc} instead", "count" -> 
       "2", "pulldown" -> "false", "default" -> 
       "{\"DPClash\", \"MannedSpaceMissionP\", \"landing\"} -> \
{\"ComputedLunarLandingDate\", \"dflt\"}", 
       "Values" -> {{
         "name" -> "ComputedLunarLandingDate", "desc" -> "lunar landing date",
           "input" -> 
          "{\"DPClash\", \"MannedSpaceMissionP\", \"landing\"} -> \
{\"ComputedLunarLandingDate\"}"}, {
         "name" -> "ComputedEarthLandingDate", "desc" -> "Earth landing date",
           "input" -> 
          "{\"DPClash\", \"MannedSpaceMissionP\", \"landing\"} -> \
{\"ComputedEarthLandingDate\"}"}}}}, "assumptions" -> {}, "open" -> {1}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      0.703184`6.298613973891088, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[16]:="],

