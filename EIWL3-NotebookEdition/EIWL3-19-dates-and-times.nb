Cell[TextData[{
 "The Wolfram Language has lots of historical real-world data. If you ask \
directly for something like the population of a country, \
it\[CloseCurlyQuote]ll give you the latest estimate it has. But you can use \
",
 ButtonBox["Dated",
  BaseStyle->"Link"],
 " to have it give you historical values. "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["The latest estimate of the population of the USA:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  TemplateBox[<|"query" -> "USA", "boxes" -> TemplateBox[{"\"United States\"", 
       RowBox[{"Entity", "[", 
         RowBox[{"\"Country\"", ",", "\"UnitedStates\""}], "]"}], 
       "\"Entity[\\\"Country\\\", \\\"UnitedStates\\\"]\"", "\"country\""}, 
      "Entity"], 
    "allassumptions" -> {{
      "type" -> "Clash", "word" -> "USA", "template" -> 
       "Assuming \"USA\" is a country${separator}Use as ${desc} instead", 
       "count" -> "2", "pulldown" -> "false", "default" -> 
       "{\"C\", \"USA\"} -> {\"Country\", \"dflt\"}", 
       "Values" -> {{
         "name" -> "Country", "desc" -> "a country", "input" -> 
          "{\"C\", \"USA\"} -> {\"Country\"}"}, {
         "name" -> "FileFormat", "desc" -> "a file format", "input" -> 
          "{\"C\", \"USA\"} -> {\"FileFormat\"}"}}}}, "assumptions" -> {}, 
    "open" -> {1}, 
    "querystate" -> {
     "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
      0.80141`6.355399750756272, "Messages" -> {}}, "contextinfo" -> 
    Automatic, "version" -> 5|>,
   "LinguisticAssistantTemplate"], "[", "\"\<Population\>\"", "]"}]], "Input",\

 Deletable->False,
 CellLabel->"In[24]:="],

Cell[BoxData[
 TemplateBox[{"331449281", "\"people\"", "people", "\"People\""},
  "Quantity"]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[24]="]
}, Open  ]],

