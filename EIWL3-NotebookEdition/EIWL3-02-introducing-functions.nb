Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{64, Inherited}, {8, 28}}],

Cell[TextData[{
 "Do I have to type the capital letters in ",
 ButtonBox["Plus",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["RandomInteger",
  BaseStyle->"Link"],
 ", etc.?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Yes. In the Wolfram Language, ",
 Cell[BoxData["plus"], "InlineCode"],
 " is not the same as ",
 ButtonBox["Plus",
  BaseStyle->"Link"],
 ". The capital letter in ",
 ButtonBox["Plus",
  BaseStyle->"Link"],
 " signifies that you\[CloseCurlyQuote]re talking about the built-in (\
\[OpenCurlyDoubleQuote]official\[CloseCurlyDoubleQuote]) plus function."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Do I have to type square brackets ",
 Cell[BoxData[
  RowBox[{"[", "\[ThinSpace]\[NegativeThinSpace]", 
   StyleBox["...",
    FontColor->GrayLevel[0.6]], "]"}]], "InlineCode"],
 " when I use functions?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 10}}],

Cell[TextData[{
 "Yes. Square brackets ",
 Cell[BoxData[
  RowBox[{"[", "\[ThinSpace]\[NegativeThinSpace]", 
   StyleBox["...",
    FontColor->GrayLevel[0.6]], "]"}]], "InlineCode"],
 " are for functions; parentheses ",
 Cell[BoxData[
  RowBox[{"(", "\[NegativeThinSpace]", "\[ThinSpace]", 
   StyleBox["...",
    FontColor->GrayLevel[0.6]], ")"}]], "InlineCode"],
 " are for grouping, as in 2*(3+4), not for functions."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 FontTracking->-0.05],

Cell[TextData[{
 "How can I tell if my brackets ",
 Cell[BoxData[
  RowBox[{"[", "\[ThinSpace]\[NegativeThinSpace]", 
   StyleBox["...",
    FontColor->GrayLevel[0.6]], "]"}]], "InlineCode"],
 " are matched?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Unmatched brackets normally get colored purple. If you click after a [ or \
before a ], its matching bracket will be indicated with a yellow background. \
In any correct input, every [ has to be matched with a ].\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "How does one read ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Plus",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"2", ",", "3"}], "]"}]], "InlineCode"],
 " out loud?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 8}}],

Cell[TextData[{
 "Usually \[OpenCurlyDoubleQuote]plus of 2 and 3\[CloseCurlyDoubleQuote]; \
sometimes \[OpenCurlyDoubleQuote]plus of 2 comma 3\[CloseCurlyDoubleQuote]. \
\[OpenCurlyDoubleQuote]",
 Cell[BoxData["["], "InlineCode"],
 "\[CloseCurlyDoubleQuote] can be read as \[OpenCurlyDoubleQuote]open bracket\
\[CloseCurlyDoubleQuote]; \[OpenCurlyDoubleQuote]",
 Cell[BoxData["]"], "InlineCode"],
 "\[CloseCurlyDoubleQuote] as \[OpenCurlyDoubleQuote]close bracket\
\[CloseCurlyDoubleQuote]."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Why use ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Plus",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"2", ",", "3"}], "]"}]], "InlineCode"],
 " instead of ",
 Cell[BoxData[
  RowBox[{"2", "+", "3"}]], "InlineCode"],
 "?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 10}}],

Cell[TextData[{
 "For ",
 ButtonBox["Plus",
  BaseStyle->"Link"],
 ", it\[CloseCurlyQuote]s not necessary. But for the vast majority of \
functions\[LongDash]like ",
 ButtonBox["Max",
  BaseStyle->"Link"],
 " or ",
 ButtonBox["RandomInteger",
  BaseStyle->"Link"],
 "\[LongDash]",
 "there\[CloseCurlyQuote]s no special form like ",
 Cell[BoxData[
  ButtonBox["+",
   BaseStyle->"Link",
   ButtonData->"Plus"]], "InlineCode"],
 ", so you have to give their names. "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Can I mix ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["Plus",
     BaseStyle->"CodeLink"], "[", "\[ThinSpace]\[NegativeThinSpace]", 
    StyleBox["...",
     FontColor->GrayLevel[0.6]], "]"}], " "}]], "InlineCode"],
 "and ",
 "+",
 "?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 10}}],

Cell[TextData[{
 "Yes. Things like ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Plus",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{"4", "+", "5"}], ",", 
    RowBox[{"2", "+", "3"}]}], "]"}]], "InlineCode"],
 " or, for that matter, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["Plus",
     BaseStyle->"CodeLink"], "[", 
    RowBox[{"4", ",", "5"}], "]"}], "*", "5"}]], "InlineCode"],
 " are just fine."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"LastCellOfAPage"],

Cell["\<\
What does it mean if the Wolfram Language colors some of my input red?\
\>", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 8}},
 CellTags->"p: 5"],

Cell[TextData[{
 "It means you\[CloseCurlyQuote]ve typed something that the Wolfram Language \
can\[CloseCurlyQuote]t understand. See ",
 ButtonBox["Section 48",
  BaseStyle->"Hyperlink",
  ButtonData->{"EIWL3-48-debugging-your-code.nb", None}],
 " for more information. Start by checking that your open and close brackets \
are matched."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 StyleBox["Expressions",
  FontSlant->"Italic"],
 " in the Wolfram Language (see ",
 ButtonBox["Section 33",
  BaseStyle->"Hyperlink",
  ButtonData->{"EIWL3-33-expressions-and-their-structure.nb", None}],
 ") consist of nested trees of functions."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["Plus",
  BaseStyle->"Link"],
 " can add any number of numbers, but ",
 ButtonBox["Subtract",
  BaseStyle->"Link"],
 " only subtracts one number from another (to avoid ambiguities between (2\
\[Minus]3)\[Minus]4 and 2\[Minus](3\[Minus]4))."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "The notion of a function is considerably more general in the Wolfram \
Language than in either traditional mathematics or computer science. For \
example, ",
 Cell[BoxData[
  RowBox[{
   StyleBox[" ", "CodeVariable"], 
   RowBox[{
    StyleBox["f", "CodeVariable"], "[", 
    StyleBox["anything", "CodeVariable"], "]"}]}]], "InlineCode"],
 " is considered a function, whether it evaluates to something definite or \
remains in symbolic form."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

