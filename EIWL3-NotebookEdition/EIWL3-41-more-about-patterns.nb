   RowBox[{"x", ">", "y"}]}]}]], "Input",
 Deletable->False,
 CellLabel->"In[5]:="],

Cell[BoxData[
 RowBox[{
  RowBox[{"check", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{"Green", "/;", 
   RowBox[{"x", "\[LessEqual]", "y"}]}]}]], "Input",
 Deletable->False,
 CellLabel->"In[6]:="],

