   ButtonBox["Table",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{
     ButtonBox["Mod",
      BaseStyle->"CodeLink"], "[", 
     RowBox[{
      RowBox[{"n", 
       ButtonBox["^",
        BaseStyle->"Link",
        ButtonData->"Power"], "2", 
       ButtonBox["+",
        BaseStyle->"Link",
        ButtonData->"Plus"], "n"}], ",", "100"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "100"}], "}"}]}], "]"}]], "InlineCode"],
