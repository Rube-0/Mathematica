}, Open  ]],

Cell[TextData[{
 "In ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y"}], "]"}]], "InlineCodeText"],
 ", ",
 Cell[BoxData["f"], "InlineCodeText"],
 " is called the ",
 StyleBox["head",
  FontSlant->"Italic"],
 " of the expression. ",
 Cell[BoxData["x"], "InlineCodeText"],
 " and ",
 Cell[BoxData["y"], "InlineCodeText"],
 " are called ",
 StyleBox["arguments",
  FontSlant->"Italic"],
 ". The function ",
 ButtonBox["Head",
  BaseStyle->"Link"],
 " extracts the head of an expression."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "The head of a list is ",
 ButtonBox["List",
  BaseStyle->"Link"],
 ":"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Head", "[", 
  RowBox[{"{", 
   RowBox[{"x", ",", "y", ",", "z"}], "}"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[21]:="],

Cell[BoxData["List"], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[21]="]
}, Open  ]],

Cell["Every part of an expression has a head, even its atoms.", "Text",
