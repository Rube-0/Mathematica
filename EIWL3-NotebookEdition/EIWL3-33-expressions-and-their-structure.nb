Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "How are ",
 Cell[BoxData[
  ButtonBox["@@",
   BaseStyle->"Link",
   ButtonData->"Apply"]], "InlineCode"],
 " and ",
 Cell[BoxData[
  ButtonBox["@@@",
   BaseStyle->"Link",
   ButtonData->"Apply"]], "InlineCode"],
 " interpreted?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   StyleBox[" ", "CodeVariable"], 
   RowBox[{
    StyleBox["f", "CodeVariable"], 
    ButtonBox["@@",
     BaseStyle->"Link",
     ButtonData->"Apply"], 
    StyleBox["expr", "CodeVariable"]}]}]], "InlineCode"],
 " is ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Apply",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    StyleBox["f", "CodeVariable"], ",", 
    StyleBox["expr", "CodeVariable"]}], "]"}]], "InlineCode"],
 ". ",
 Cell[BoxData[
  RowBox[{
   StyleBox[" ", "CodeVariable"], 
   RowBox[{
    StyleBox["f", "CodeVariable"], 
    ButtonBox["@@@",
     BaseStyle->"Link",
     ButtonData->"Apply"], 
    StyleBox["expr", "CodeVariable"]}]}]], "InlineCode"],
 " is ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["MapApply",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    StyleBox["f", "CodeVariable"], ",", 
    StyleBox["expr", "CodeVariable"]}], "]"}]], "InlineCode"],
 " or ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Apply",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    StyleBox["f", "CodeVariable"], ",", 
    StyleBox["expr", "CodeVariable"], ",", 
    RowBox[{"{", "1", "}"}]}], "]"}]], "InlineCode"],
 ". They\[CloseCurlyQuote]re usually just read as \
\[OpenCurlyDoubleQuote]double at\[CloseCurlyDoubleQuote] and \
\[OpenCurlyDoubleQuote]triple at\[CloseCurlyDoubleQuote]."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Are all expressions in the Wolfram Language trees?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "At a structural level, yes. When there are variables with values assigned \
(see ",
 ButtonBox["Section 38",
  BaseStyle->"Hyperlink",
  ButtonData->{"EIWL3-38-assigning-names-to-things.nb", None}],
 "), though, they can behave more like directed graphs. And of course one can \
use ",
 ButtonBox["Graph",
  BaseStyle->"Link"],
 " to represent any graph as an expression in the Wolfram Language."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
The basic concept of symbolic languages comes directly from work in \
mathematical logic stretching back to the 1930s and before, but other than in \
the Wolfram Language it\[CloseCurlyQuote]s been very rare for it to be \
implemented in practice.\
\>", "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Wolfram Language expressions are a bit like XML expressions (and can be \
converted to and from them). But unlike XML expressions, Wolfram Language \
expressions can evaluate so that they automatically change their structure.\
\>", "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Things like ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Select",
    BaseStyle->"CodeLink"], "[", 
   StyleBox["f", "CodeVariable"], "]"}]], "InlineCode"],
 " that are set up to be applied to expressions are called ",
 StyleBox["operator forms",
  FontSlant->"Italic"],
 ", by analogy with operators in mathematics. Using ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["Select",
     BaseStyle->"CodeLink"], "[", 
    StyleBox["f", "CodeVariable"], "]"}], "[", 
   StyleBox["expr", "CodeVariable"], "]"}]], "InlineCode"],
 " instead of ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Select",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    StyleBox["expr", "CodeVariable"], ",", 
    StyleBox["f", "CodeVariable"]}], "]"}]], "InlineCode"],
 " is often called ",
 StyleBox["currying",
  FontSlant->"Italic"],
 ", after a logician named Haskell Curry. ",
 ButtonBox["OperatorApplied",
  BaseStyle->"Link"],
 " or ",
 ButtonBox["CurryApplied",
  BaseStyle->"Link"],
 " let you \[OpenCurlyDoubleQuote]make operator forms\[CloseCurlyDoubleQuote] \
for anything. For example, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    ButtonBox["OperatorApplied",
     BaseStyle->"CodeLink"], "[", 
    StyleBox["f", "CodeVariable"], "]"}], "[", 
   StyleBox["x", "CodeVariable"], "]"}]], "InlineCode"],
 " applied to ",
 Cell[BoxData[
  StyleBox["expr", "CodeVariable"]], "InlineCode"],
 " gives ",
 Cell[BoxData[
  RowBox[{
   StyleBox[" ", "CodeVariable"], 
   RowBox[{
    StyleBox["f", "CodeVariable"], "[", 
    RowBox[{
     StyleBox["expr", "CodeVariable"], ",", 
     StyleBox["x", "CodeVariable"]}], "]"}]}]], "InlineCode"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 LineSpacing->{1.15, 1., 2.}],

Cell[TextData[{
 "Symbols like ",
 Cell[BoxData["x"], "InlineCode"],
 " can be used to represent algebraic variables or \
\[OpenCurlyDoubleQuote]unknowns\[CloseCurlyDoubleQuote]. This is central to \
doing many kinds of mathematics in the Wolfram Language."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["LeafCount",
  BaseStyle->"Link"],
 " gives the total number of atoms at the leaves of an expression tree. ",
 ButtonBox["ByteCount",
  BaseStyle->"Link"],
 " gives the number of bytes needed to store the expression."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["ExpressionTree",
  BaseStyle->"Link"],
 " generates a ",
 ButtonBox["Tree",
  BaseStyle->"Link"],
 " object, on which many operations can be done. ",
 ButtonBox["ExpressionGraph",
  BaseStyle->"Link"],
 " gives the tree for an expression as a ",
 ButtonBox["Graph",
  BaseStyle->"Link"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

