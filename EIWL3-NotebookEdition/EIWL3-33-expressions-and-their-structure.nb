Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 InterpretationBox[Cell["Expressions and Their Structure", "SectionInline"],
  $Line = 0; Null]], "SectionDoubleDigit",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CounterAssignments->{{"Section", 32}, {"Subsection", 0}, {
   "Subsubsection", 0}, {"Exercise", 0}},
 CellTags->"p: 209",
 CellLabel->"In[15]:="],

Cell[TextData[{
 "We\[CloseCurlyQuote]ve now seen all sorts of things that exist in the \
Wolfram Language: lists, graphics, pure functions and much more. And now we\
\[CloseCurlyQuote]re ready to discuss a very fundamental fact about the \
Wolfram Language: that each of these things\[LongDash]and in fact everything \
the language deals with\[LongDash]is ultimately constructed in the same basic \
kind of way. Everything is what\[CloseCurlyQuote]s called a ",
 StyleBox["symbolic expression",
  FontSlant->"Italic"],
 ". "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Symbolic expressions are a very general way to represent structure, \
potentially with meaning associated with that structure. ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y"}], "]"}]], "InlineCodeText"],
 " is a simple example of a symbolic expression. On its own, this symbolic \
expression doesn\[CloseCurlyQuote]t have any particular meaning attached, and \
if you type it into the Wolfram Language, it\[CloseCurlyQuote]ll just come \
back unchanged. "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y"}], "]"}]], "InlineCode"],
 " is a symbolic expression with no particular meaning attached: "
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"f", "[", 
  RowBox[{"x", ",", "y"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[1]:="],

Cell[BoxData[
 RowBox[{"f", "[", 
  RowBox[{"x", ",", "y"}], "]"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[1]="]
}, Open  ]],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"x", ",", "y", ",", "z"}], "}"}]], "InlineCodeText"],
 " is another symbolic expression. Internally, it\[CloseCurlyQuote]s ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["List",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"x", ",", "y", ",", "z"}], "]"}]], "InlineCodeText"],
 ", but it\[CloseCurlyQuote]s displayed as ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"x", ",", "y", ",", "z"}], "}"}]], "InlineCodeText"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "The symbolic expression ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["List",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"x", ",", "y", ",", "z"}], "]"}]], "InlineCode"],
 " displays as ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"x", ",", "y", ",", "z"}], "}"}]], "InlineCode"],
 ":"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"List", "[", 
  RowBox[{"x", ",", "y", ",", "z"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[2]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"x", ",", "y", ",", "z"}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[2]="]
}, Open  ]],

Cell["Symbolic expressions are often nested:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"List", "[", 
  RowBox[{
   RowBox[{"List", "[", 
    RowBox[{"a", ",", "b"}], "]"}], ",", 
   RowBox[{"List", "[", 
    RowBox[{"c", ",", "d"}], "]"}]}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[3]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"a", ",", "b"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"c", ",", "d"}], "}"}]}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[3]="]
}, Open  ]],

Cell[TextData[{
 ButtonBox["FullForm",
  BaseStyle->"Link"],
 " shows you the internal form of any symbolic expression. "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullForm", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "b"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"c", ",", "d"}], "}"}]}], "}"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[4]:="],

Cell[BoxData[
 TagBox[
  StyleBox[
   RowBox[{"List", "[", 
    RowBox[{
     RowBox[{"List", "[", 
      RowBox[{"a", ",", "b"}], "]"}], ",", 
     RowBox[{"List", "[", 
      RowBox[{"c", ",", "d"}], "]"}]}], "]"}],
   ShowSpecialCharacters->False,
   ShowStringCharacters->True,
   NumberMarks->True],
  FullForm]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[4]//FullForm="]
}, Open  ]],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["Graphics",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    ButtonBox["Circle",
     BaseStyle->"CodeLink"], "[", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}], "]"}], "]"}]], "InlineCodeText"],
 " is another symbolic expression, that just happens to display as a picture \
of a circle. ",
 ButtonBox["FullForm",
  BaseStyle->"Link"],
 " shows its internal structure."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["This symbolic expression displays as a circle:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Graphics", "[", 
  RowBox[{"Circle", "[", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0"}], "}"}], "]"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[5]:="],

Cell[BoxData[
 GraphicsBox[CircleBox[{0, 0}],
  ImageSize->{39.3125, Automatic}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellTags->"LastCellOfAPage",
 CellLabel->"Out[5]="]
}, Open  ]],

Cell[TextData[{
 ButtonBox["FullForm",
  BaseStyle->"Link"],
 " shows its underlying symbolic expression structure:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 210"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullForm", "[", 
  GraphicsBox[CircleBox[{0, 0}],
   ImageSize->{37.328125, Automatic}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[6]:="],

Cell[BoxData[
 TagBox[
  StyleBox[
   RowBox[{"Graphics", "[", 
    RowBox[{"Circle", "[", 
     RowBox[{"List", "[", 
      RowBox[{"0", ",", "0"}], "]"}], "]"}], "]"}],
   ShowSpecialCharacters->False,
   ShowStringCharacters->True,
   NumberMarks->True],
  FullForm]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[6]//FullForm="]
}, Open  ]],

Cell[TextData[{
 "Symbolic expressions often don\[CloseCurlyQuote]t just display in special \
ways, they actually ",
 StyleBox["evaluate",
  FontSlant->"Italic"],
 " to give results. "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["A symbolic expression that evaluates to give a result:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plus", "[", 
  RowBox[{"2", ",", "2"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[7]:="],

Cell[BoxData["4"], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[7]="]
}, Open  ]],

Cell["\<\
The elements of the list evaluate, but the list itself stays symbolic:\
\>", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Plus", "[", 
    RowBox[{"3", ",", "3"}], "]"}], ",", 
   RowBox[{"Times", "[", 
    RowBox[{"3", ",", "3"}], "]"}], ",", 
   RowBox[{"Power", "[", 
    RowBox[{"3", ",", "3"}], "]"}]}], "}"}]], "Input",
 Deletable->False,
 CellLabel->"In[8]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"6", ",", "9", ",", "27"}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[8]="]
}, Open  ]],

Cell["Here\[CloseCurlyQuote]s the symbolic expression structure of the \
list:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Plus", "[", 
     RowBox[{"3", ",", "3"}], "]"}], ",", 
    RowBox[{"Times", "[", 
     RowBox[{"3", ",", "3"}], "]"}], ",", 
    RowBox[{"Power", "[", 
     RowBox[{"3", ",", "3"}], "]"}]}], "}"}], "//", "FullForm"}]], "Input",
 Deletable->False,
 CellLabel->"In[9]:="],

Cell[BoxData[
 TagBox[
  StyleBox[
   RowBox[{"List", "[", 
    RowBox[{"6", ",", "9", ",", "27"}], "]"}],
   ShowSpecialCharacters->False,
   ShowStringCharacters->True,
   NumberMarks->True],
  FullForm]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[9]//FullForm="]
}, Open  ]],

Cell["This is just a symbolic expression that happens to evaluate:", \
