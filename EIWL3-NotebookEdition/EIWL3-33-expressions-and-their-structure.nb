}, Open  ]],

Cell[TextData[{
 "In patterns, you can ask to match expressions with particular heads. ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["_",
    BaseStyle->"Link",
    ButtonData->"Blank"], 
   ButtonBox["Integer",
    BaseStyle->"CodeLink"]}]], "InlineCodeText"],
 " represents any integer, ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["_",
    BaseStyle->"Link",
    ButtonData->"Blank"], 
   ButtonBox["String",
    BaseStyle->"CodeLink"]}]], "InlineCodeText"],
 " any string and so on."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["_",
    BaseStyle->"Link",
    ButtonData->"Blank"], 
   ButtonBox["Integer",
    BaseStyle->"CodeLink"]}]], "InlineCode"],
 " is a pattern that matches only objects with head ",
 ButtonBox["Integer",
  BaseStyle->"Link"],
 ":"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Cases", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", ",", "y", ",", "3", ",", "4", ",", "z", ",", "6", ",", "7"}],
     "}"}], ",", "_Integer"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[26]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"3", ",", "4", ",", "6", ",", "7"}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[26]="]
}, Open  ]],

Cell["Named patterns can have specified heads too:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Cases", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"99", ",", "x", ",", "y", ",", "z", ",", "101", ",", "102"}], 
    "}"}], ",", 
   RowBox[{"n_Integer", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"n", ",", "n"}], "}"}]}]}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[27]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"99", ",", "99"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"101", ",", "101"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"102", ",", "102"}], "}"}]}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[27]="]
}, Open  ]],

Cell["\<\
In using the Wolfram Language, most of the heads you\[CloseCurlyQuote]ll see \
are symbols. But there are important cases where there are more complicated \
heads. One such case is pure functions\[LongDash]where when you apply a pure \
function, the pure function appears as the head.\
\>", "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Here is the full form of a pure function (",
 Cell[BoxData[
  ButtonBox["#",
   BaseStyle->"Link",
   ButtonData->"Slot"]], "InlineCode"],
 " is ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Slot",
    BaseStyle->"CodeLink"], "[", "1", "]"}]], "InlineCode"],
 "):"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullForm", "[", 
  RowBox[{
   RowBox[{"#", "^", "2"}], "&"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[28]:="],

Cell[BoxData[
 TagBox[
  StyleBox[
   RowBox[{"Function", "[", 
    RowBox[{"Power", "[", 
     RowBox[{
      RowBox[{"Slot", "[", "1", "]"}], ",", "2"}], "]"}], "]"}],
   ShowSpecialCharacters->False,
   ShowStringCharacters->True,
   NumberMarks->True],
  FullForm]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[28]//FullForm="]
}, Open  ]],

