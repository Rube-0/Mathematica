Cell[CellGroupData[{

Cell[TextData[{
 "Find the unique cases where ",
 Cell[BoxData[
  RowBox[{"i", 
   ButtonBox["^",
    BaseStyle->"Link",
    ButtonData->"Power"], 
   RowBox[{"2", "/", 
    RowBox[{"(", 
     RowBox[{"j", 
      ButtonBox["^",
       BaseStyle->"Link",
       ButtonData->"Power"], "2", 
      ButtonBox["+",
       BaseStyle->"Link",
       ButtonData->"Plus"], "1"}], ")"}]}]}]], "InlineCode"],
 " is an integer, with ",
 Cell[BoxData["i"], "InlineCode"],
 " and ",
 Cell[BoxData["j"], "InlineCode"],
 " going up to 20.",
 StyleBox[ButtonBox["\[NonBreakingSpace]\[RightGuillemet]",
  Appearance->None,
  Evaluator->Automatic,
  Method->"Preemptive",
  ButtonFunction:>(SelectionMove[
     ButtonNotebook[], All, ButtonCell, AutoScroll -> False]; 
   FrontEndExecute[
     FrontEndToken[
      ButtonNotebook[], "OpenCloseGroup"]])],
  FontColor->RGBColor[1, 0.501961, 0]]
}], "Exercise",
