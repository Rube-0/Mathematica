Cell[TextData[{
 "What are the ultimate building blocks of symbolic expressions? They\
\[CloseCurlyQuote]re called ",
 StyleBox["atoms",
  FontSlant->"Italic"],
 " (after the building blocks of physical materials). The main kinds of atoms \
are numbers, ",
 "strings",
 " and ",
 StyleBox["symbols",
  FontSlant->"Italic"],
 ". "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Things like ",
 Cell[BoxData["x"], "InlineCodeText"],
 ", ",
 Cell[BoxData["y"], "InlineCodeText"],
 ", ",
 Cell[BoxData["f"], "InlineCodeText"],
 ", ",
 ButtonBox["Plus",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["Graphics",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["Table",
  BaseStyle->"Link"],
 " are all symbols. Every symbol has a unique name. Sometimes it\
\[CloseCurlyQuote]ll also have a meaning attached. Sometimes it\
\[CloseCurlyQuote]ll be associated with evaluation. Sometimes it\
\[CloseCurlyQuote]ll just be part of defining a structure that other \
functions can use. But it ",
 "doesn\[CloseCurlyQuote]t have to have",
 " any of those things; it just has to have a name."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"LastCellOfAPage"],

Cell["\<\
A crucial defining feature of the Wolfram Language is that it can handle \
symbols purely as symbols\[LongDash]\[OpenCurlyDoubleQuote]symbolically\
\[CloseCurlyDoubleQuote]\[LongDash]without them having to evaluate, say to \
numbers. \
\>", "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 211"],

Cell[TextData[{
 "In the Wolfram Language, ",
 Cell[BoxData["x"], "InlineCode"],
 " can just be ",
 Cell[BoxData["x"], "InlineCode"],
 ", without having to evaluate to anything:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData["x"], "Input",
 Deletable->False,
 CellLabel->"In[12]:="],

Cell[BoxData["x"], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[12]="]
}, Open  ]],

Cell[TextData[{
 Cell[BoxData["x"], "InlineCode"],
 " does not evaluate, but the addition is still done, here according to the \
laws of algebra: "
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"x", "+", "x", "+", "x", "+", 
  RowBox[{"2", "y"}], "+", "y", "+", "x"}]], "Input",
 Deletable->False,
 CellLabel->"In[13]:="],

Cell[BoxData[
 RowBox[{
  RowBox[{"4", " ", "x"}], "+", 
  RowBox[{"3", " ", "y"}]}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[13]="]
}, Open  ]],

Cell[TextData[{
 "Given symbols like ",
 Cell[BoxData["x"], "InlineCodeText"],
 ", ",
 Cell[BoxData["y"], "InlineCodeText"],
 " and ",
 Cell[BoxData["f"], "InlineCodeText"],
 ", one can build up an infinite number of expressions from them. There\
\[CloseCurlyQuote]s ",
 Cell[BoxData[
  RowBox[{"f", "[", "x", "]"}]], "InlineCodeText"],
 ", and ",
 Cell[BoxData[
  RowBox[{"f", "[", "y", "]"}]], "InlineCodeText"],
 ", and ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"x", ",", "y"}], "]"}]], "InlineCodeText"],
 ". Then there\[CloseCurlyQuote]s ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"f", "[", "x", "]"}], "]"}]], "InlineCodeText"],
 " or ",
 Cell[BoxData[
  RowBox[{"f", "[", 
   RowBox[{"x", ",", 
    RowBox[{"f", "[", 
     RowBox[{"x", ",", "y"}], "]"}]}], "]"}]], "InlineCodeText"],
 ", or, for that matter, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"x", "[", "x", "]"}], "[", 
   RowBox[{"y", ",", 
    RowBox[{"f", "[", "x", "]"}]}], "]"}]], "InlineCodeText"],
 " or whatever. "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "In general, each expression corresponds to a tree, whose ultimate \
\[OpenCurlyDoubleQuote]leaves\[CloseCurlyDoubleQuote] are atoms. You can show \
an expression as a tree using ",
 ButtonBox["ExpressionTree",
  BaseStyle->"Link"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["An expression shown as a tree:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ExpressionTree", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"x", ",", 
      RowBox[{"f", "[", 
       RowBox[{"x", ",", "y"}], "]"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y", ",", 
      RowBox[{"f", "[", "1", "]"}]}], "}"}]}], "}"}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[1435]:="],

