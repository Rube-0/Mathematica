Cell["\<\
Here\[CloseCurlyQuote]s a direct way to apply a pure function to an \
association.\
\>", "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Apply a pure function to an association:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{
     RowBox[{"#", "[", "\"\<apples\>\"", "]"}], ",", 
     RowBox[{"#", "[", "\"\<oranges\>\"", "]"}]}], "]"}], "&"}], "[", 
  RowBox[{"\[LeftAssociation]", 
   RowBox[{
    RowBox[{"\"\<apples\>\"", "\[Rule]", "10"}], ",", 
    RowBox[{"\"\<oranges\>\"", "\[Rule]", "12"}], ",", 
    RowBox[{"\"\<pears\>\"", "\[Rule]", "4"}]}], "\[RightAssociation]"}], 
  "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[15]:="],

Cell[BoxData[
 RowBox[{"f", "[", 
  RowBox[{"10", ",", "12"}], "]"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[15]="]
}, Open  ]],

Cell[TextData[{
 "It\[CloseCurlyQuote]s very common to have keys that are strings, and the \
Wolfram Language has a special way to ",
 "handle these when it comes to pure functions",
 ": you can just use ",
 Cell[BoxData["#key"], "InlineCodeText"],
 " to refer to an element whose key is ",
 Cell[BoxData["\"\<key\>\""], "InlineCodeText"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Use the simpler notation for association elements whose keys are strings:\
\>", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", 
     RowBox[{"#apples", ",", "#oranges"}], "]"}], "&"}], "[", 
   RowBox[{"\[LeftAssociation]", 
    RowBox[{
     RowBox[{"\"\<apples\>\"", "\[Rule]", "10"}], ",", 
     RowBox[{"\"\<oranges\>\"", "\[Rule]", "12"}], ",", 
     RowBox[{"\"\<pears\>\"", "\[Rule]", "4"}]}], "\[RightAssociation]"}], 
