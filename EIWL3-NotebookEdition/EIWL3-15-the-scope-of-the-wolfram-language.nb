Cell[TextData[{
 "All the functions in the Wolfram Language follow the same principles\
\[LongDash]so for example the ",
 ButtonBox["Parallelogram",
  BaseStyle->"Link"],
 " function works very much like the ",
 ButtonBox["RegularPolygon",
  BaseStyle->"Link"],
 " function that we already discussed."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"c4a5f257-7897-4c46-89e0-a47e7231580a"]
}, Open  ]],

