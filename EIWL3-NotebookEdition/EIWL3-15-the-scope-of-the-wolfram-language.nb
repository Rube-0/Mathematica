 CellTags->"p: 77",ExpressionUUID->"1891833a-d0ae-488c-be4e-58694d71fb62"],

Cell["\<\
In the past 14 sections, we\[CloseCurlyQuote]ve seen many things the Wolfram \
Language can do. But what we\[CloseCurlyQuote]ve seen is only the very \
beginning. We\[CloseCurlyQuote]ve discussed around 85 built-in functions\
\[LongDash]but altogether the language has more than 6000.\
\>", "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"f10ee76d-5d56-4eb4-a2f6-cb212a33ed26"],

Cell[TextData[{
 "You can go to the ",
 ButtonBox["Documentation Center",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/"], None},
  ButtonNote->"http://reference.wolfram.com/language/"],
 " to start exploring all these functions."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"0f7e1727-ab27-48cb-bd80-f5ccc7bdffb2"],

