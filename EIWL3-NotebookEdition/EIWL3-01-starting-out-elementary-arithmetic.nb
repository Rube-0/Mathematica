 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellBaseline->16,
 LineSpacing->{1.15, 1., 2.}],

Cell["Why is multiplication indicated by *?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Because the * (\[OpenCurlyDoubleQuote]star\[CloseCurlyDoubleQuote], \
typically typed as ",
 Cell[BoxData[
  TemplateBox[{"shift", "8"},
   "Key1"]]],
 ") looks like a multiplication sign. In the Wolfram Language, you can also \
just put a space between numbers you want to multiply; t",
 StyleBox["he Wolfram Language will then automatically insert a ",
  Background->None],
 Cell[BoxData[
  ButtonBox["\[Times]",
   BaseStyle->"Link",
   ButtonData->"Times"]], "InlineCode"],
 StyleBox[" multiplication sign.",
  Background->None]
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "What does \[OpenCurlyDoubleQuote]raised to the \
power\[CloseCurlyDoubleQuote] (",
 Cell[BoxData[
  ButtonBox["^",
   BaseStyle->"Link",
   ButtonData->"Power"]], "InlineCode"],
 ") mean?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
6^3 means 6\[Times]6\[Times]6 (i.e. 6 multiplied by itself 3 times); 10^5 \
means 10\[Times]10\[Times]10\[Times]10\[Times]10; etc.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["How big can numbers get in the Wolfram Language?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 8}}],

Cell["\<\
As big as you want\[LongDash]so long as they fit in your computer\
\[CloseCurlyQuote]s memory. \
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["What is the order of operations in the Wolfram Language?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 8}}],

Cell[TextData[{
 "The same as in ordinary math: powers, multiplication, addition. So 4*5^2+7 \
means (4*(5^2))+7. You can use parentheses just like in math. (In math, \
people sometimes use [",
 StyleBox["...",
  FontColor->GrayLevel[0.6]],
 "] as well as (",
 StyleBox["...",
  FontColor->GrayLevel[0.6]],
 "). In the Wolfram Language [",
 StyleBox["...",
  FontColor->GrayLevel[0.6]],
 "] means something different.)"
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
When I do division, how do I avoid getting fractions in my answer?\
\>", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "If you put in numbers with decimal points, you\[CloseCurlyQuote]ll get out \
numbers with decimal points. You can also use ",
 ButtonBox["N",
  BaseStyle->"Link"],
 ", as we discuss in ",
 ButtonBox["Section 23",
  BaseStyle->"Hyperlink",
  ButtonData->{"EIWL3-23-more-about-numbers.nb", "N"}],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
What are the little spaces between digits in results like 7\[ThinSpace]006\
\[ThinSpace]652?\
\>", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
They\[CloseCurlyQuote]re there to help you read the number when it\
\[CloseCurlyQuote]s displayed; they\[CloseCurlyQuote]re not part of the \
number. \
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["How do I enter a big number?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 8}}],

Cell["\<\
Just type the digits, without putting any commas, spaces or other separators \
(e.g. 1234123511415223).\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "What happens if I compute ",
 Cell[BoxData[
  RowBox[{"1", "/", "0"}]], "InlineCode"],
 "?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Try it! You\[CloseCurlyQuote]ll get a symbolic representation of infinity, on \
which the Wolfram Language can then do further computations.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

