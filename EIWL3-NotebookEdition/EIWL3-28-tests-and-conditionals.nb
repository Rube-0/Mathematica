 ShowCellBracket->False],

Cell[TextData[{
 "5 appears in the list ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1", ",", "3", ",", "5", ",", "7"}], "}"}]], "InlineCode"],
 ":"
}], "CodeCaption",
