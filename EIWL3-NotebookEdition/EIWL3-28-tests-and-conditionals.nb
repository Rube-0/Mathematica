 Deletable->False,
 CellLabel->"In[9]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"2", ",", "3", ",", "4", ",", "5"}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[9]="]
}, Open  ]],

Cell[TextData[{
 "Beyond size comparisons like ",
 Cell[BoxData[
  ButtonBox["<",
   BaseStyle->"Link",
   ButtonData->"Less"]], "InlineCodeText"],
 ", ",
 Cell[BoxData[
  ButtonBox[">",
   BaseStyle->"Link",
   ButtonData->"Greater"]], "InlineCodeText"],
 " and ",
 Cell[BoxData[
  ButtonBox["==",
   BaseStyle->"Link",
   ButtonData->"Equal"]], "InlineCodeText"],
 ", the Wolfram Language includes many other kinds of tests. Examples are ",
 ButtonBox["EvenQ",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["OddQ",
  BaseStyle->"Link"],
 ", which test whether numbers are even or odd. (The \
\[OpenCurlyDoubleQuote]",
 Cell[BoxData["Q"], "InlineCodeText"],
 "\[CloseCurlyDoubleQuote] indicates that the functions are asking a \
question.)"
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

