Cell["Is 2+2 equal to 4? Let\[CloseCurlyQuote]s ask the Wolfram Language.", \
"Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Test whether 2+2 is equal to 4:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"2", "+", "2"}], "\[Equal]", "4"}]], "Input",
 Deletable->False,
 CellLabel->"In[1]:="],

Cell[BoxData["True"], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[1]="]
}, Open  ]],

Cell[TextData[{
 "Not surprisingly, testing whether 2+2 is equal to 4 ",
 "gives ",
 ButtonBox["True",
  BaseStyle->"Link"],
 ". "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "We can also test whether 2\[Times]2 is greater than 5. We do that using ",
 Cell[BoxData[
  ButtonBox[">",
   BaseStyle->"Link",
   ButtonData->"Greater"]], "InlineCodeText"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["Test whether 2\[Times]2 is greater than 5:", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"2", "*", "2"}], ">", "5"}]], "Input",
 Deletable->False,
 CellLabel->"In[2]:="],

Cell[BoxData["False"], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[2]="]
}, Open  ]],

Cell[TextData[{
 "The function ",
 ButtonBox["If",
  BaseStyle->"Link"],
 " lets you choose to give one result if a test is ",
 ButtonBox["True",
  BaseStyle->"Link"],
 ", and another if it\[CloseCurlyQuote]s ",
 ButtonBox["False",
  BaseStyle->"Link"],
 ". "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Since ",
 "the",
 " test gives ",
 ButtonBox["True",
  BaseStyle->"Link"],
 ", the result of the ",
 ButtonBox["If",
  BaseStyle->"Link"],
 " is ",
 Cell[BoxData["x"], "InlineCode"],
 ":"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"2", "+", "2"}], "\[Equal]", "4"}], ",", "x", ",", "y"}], 
  "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[3]:="],

Cell[BoxData["x"], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[3]="]
}, Open  ]],

Cell[TextData[{
 "By using a pure function with ",
 Cell[BoxData[
  ButtonBox["/@",
   BaseStyle->"Link",
   ButtonData->"Map"]], "InlineCodeText"],
 ", we can apply an ",
 ButtonBox["If",
  BaseStyle->"Link"],
 " to every element of a list. "
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "If an element is less than 4, make it ",
 Cell[BoxData["x"], "InlineCode"],
 ", otherwise make it ",
 Cell[BoxData["y"], "InlineCode"],
 ":"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"#", "<", "4"}], ",", "x", ",", "y"}], "]"}], "&"}], "/@", 
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6", ",", "7"}], 
   "}"}]}]], "Input",
 Deletable->False,
 CellLabel->"In[4]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"x", ",", "x", ",", "x", ",", "y", ",", "y", ",", "y", ",", "y"}], 
  "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[4]="]
}, Open  ]],

Cell[TextData[{
 "You can also test for less than or equal using ",
 Cell[BoxData[
  ButtonBox["\[LessEqual]",
   BaseStyle->"Link",
   ButtonData->"LessEqual"]], "InlineCodeText"],
 ", which is typed as ",
 Cell[BoxData["<="], "InlineCode"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "If an element is less than or equal to 4, make it ",
 Cell[BoxData["x"], "InlineCode"],
 "; otherwise, make it ",
 Cell[BoxData["y"], "InlineCode"],
 ":"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"#", "\[LessEqual]", " ", "4"}], ",", "x", ",", "y"}], "]"}], 
   "&"}], "/@", 
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6", ",", "7"}], 
   "}"}]}]], "Input",
 Deletable->False,
 CellLabel->"In[5]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"x", ",", "x", ",", "x", ",", "x", ",", "y", ",", "y", ",", "y"}], 
  "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[5]="]
}, Open  ]],

Cell[TextData[{
 "This makes ",
 "an",
 " element ",
 Cell[BoxData["x"], "InlineCode"],
 " only if it is equal to 4:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"#", "==", " ", "4"}], ",", "x", ",", "y"}], "]"}], "&"}], "/@", 
  
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6", ",", "7"}], 
   "}"}]}]], "Input",
 Deletable->False,
 CellLabel->"In[6]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"y", ",", "y", ",", "y", ",", "x", ",", "y", ",", "y", ",", "y"}], 
  "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[6]="]
}, Open  ]],

Cell[TextData[{
 "You can test whether two things are not equal using ",
