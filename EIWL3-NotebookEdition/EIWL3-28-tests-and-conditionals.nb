Cell[TextData[{
 "Sometimes we need to combine tests. ",
 Cell[BoxData[
  ButtonBox["&&",
   BaseStyle->"Link",
   ButtonData->"And"]], "InlineCodeText"],
 " represents \[OpenCurlyDoubleQuote]and\[CloseCurlyDoubleQuote], ",
 Cell[BoxData[
  ButtonBox["||",
   BaseStyle->"Link",
   ButtonData->"Or"]], "InlineCodeText"],
 " represents \[OpenCurlyDoubleQuote]or\[CloseCurlyDoubleQuote] and ",
 Cell[BoxData[
  ButtonBox["!",
   BaseStyle->"Link",
   ButtonData->"Not"]], "InlineCodeText"],
 " represents \[OpenCurlyDoubleQuote]not\[CloseCurlyDoubleQuote]."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Select elements of the list that are both even and greater than 2:\
\>", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Select", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6", ",", "7"}],
     "}"}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"EvenQ", "[", "#", "]"}], "&&", 
     RowBox[{"#", ">", "2"}]}], "&"}]}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[14]:="],

Cell[BoxData[
 RowBox[{"{", 
