      ",", "9"}], "}"}], ",", 
   RowBox[{
    RowBox[{"EvenQ", "[", "#", "]"}], "&"}]}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[11]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"2", ",", "4", ",", "6", ",", "8"}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[11]="]
}, Open  ]],

Cell["In this case, we don\[CloseCurlyQuote]t need the explicit pure \
