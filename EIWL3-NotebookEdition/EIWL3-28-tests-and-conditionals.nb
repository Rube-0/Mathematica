Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Why does one test equality with ",
 Cell[BoxData[
  ButtonBox["==",
   BaseStyle->"Link",
   ButtonData->"Equal"]], "InlineCode"],
 " not ",
 Cell[BoxData[
  ButtonBox["=",
   BaseStyle->"Link",
   ButtonData->"Set"]], "InlineCode"],
 "?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Because ",
 Cell[BoxData[
  ButtonBox["=",
   BaseStyle->"Link",
   ButtonData->"Set"]], "InlineCode"],
 " means something else in the Wolfram Language. You\[CloseCurlyQuote]ll get \
very strange results if you use ",
 Cell[BoxData[
  ButtonBox["=",
   BaseStyle->"Link",
   ButtonData->"Set"]], "InlineCode"],
 " instead of ",
 Cell[BoxData[
  ButtonBox["==",
   BaseStyle->"Link",
   ButtonData->"Equal"]], "InlineCode"],
 " by mistake. (",
 Cell[BoxData[
  ButtonBox["=",
   BaseStyle->"Link",
   ButtonData->"Set"]], "InlineCode"],
 " is for assigning values of variables.) To avoid possible confusion, ",
 Cell[BoxData[
  ButtonBox["==",
   BaseStyle->"Link",
   ButtonData->"Equal"]], "InlineCode"],
 " is often read as \[OpenCurlyDoubleQuote]double equals\
\[CloseCurlyDoubleQuote]."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Why is \[OpenCurlyDoubleQuote]and\[CloseCurlyDoubleQuote] written as ",
 Cell[BoxData[
  ButtonBox["&&",
   BaseStyle->"Link",
   ButtonData->"And"]], "InlineCode"],
 ", not ",
 Cell[BoxData[
  ButtonBox["&",
   BaseStyle->"Link",
   ButtonData->"Function"]], "InlineCode"],
 "?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Because ",
 Cell[BoxData[
  ButtonBox["&",
   BaseStyle->"Link",
   ButtonData->"Function"]], "InlineCode"],
 " means other things in the Wolfram Language. For example it\
\[CloseCurlyQuote]s what ends a ",
 "pure function",
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"LastCellOfAPage"],

Cell[TextData[{
 "How are ",
 Cell[BoxData[
  ButtonBox["==",
   BaseStyle->"Link",
   ButtonData->"Equal"]], "InlineCode"],
 ", ",
 Cell[BoxData[
  ButtonBox[">",
   BaseStyle->"Link",
   ButtonData->"Greater"]], "InlineCode"],
 ", ",
 Cell[BoxData[
  ButtonBox["&&",
   BaseStyle->"Link",
   ButtonData->"And"]], "InlineCode"],
 ", etc. interpreted?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 180"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["==",
   BaseStyle->"Link",
   ButtonData->"Equal"]], "InlineCode"],
 " is ",
 ButtonBox["Equal",
  BaseStyle->"Link"],
 ", ",
 Cell[BoxData[
  ButtonBox["\[NotEqual]",
   BaseStyle->"Link",
   ButtonData->"Unequal"]], "InlineCode"],
 " (",
 Cell[BoxData[
  ButtonBox["!=",
   BaseStyle->"Link",
   ButtonData->"Unequal"]], "InlineCode"],
 ") is ",
 ButtonBox["Unequal",
  BaseStyle->"Link"],
 ", ",
 Cell[BoxData[
  ButtonBox[">",
   BaseStyle->"Link",
   ButtonData->"Greater"]], "InlineCode"],
 " is ",
 ButtonBox["Greater",
  BaseStyle->"Link"],
 ", ",
 Cell[BoxData[
  ButtonBox["\[GreaterEqual]",
   BaseStyle->"Link",
   ButtonData->"GreaterEqual"]], "InlineCode"],
 " is ",
 ButtonBox["GreaterEqual",
  BaseStyle->"Link"],
 ", ",
 Cell[BoxData[
  ButtonBox["<",
   BaseStyle->"Link",
   ButtonData->"Less"]], "InlineCode"],
 " is ",
 ButtonBox["Less",
  BaseStyle->"Link"],
 ", ",
 Cell[BoxData[
  ButtonBox["&&",
   BaseStyle->"Link",
   ButtonData->"And"]], "InlineCode"],
 " is ",
 ButtonBox["And",
  BaseStyle->"Link"],
 ", ",
 Cell[BoxData[
  ButtonBox["||",
   BaseStyle->"Link",
   ButtonData->"Or"]], "InlineCode"],
 " is ",
 ButtonBox["Or",
  BaseStyle->"Link"],
 " and ",
 Cell[BoxData[
  ButtonBox["!",
   BaseStyle->"Link",
   ButtonData->"Not"]], "InlineCode"],
 " is ",
 ButtonBox["Not",
  BaseStyle->"Link"],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "When do I ",
 "need to use parentheses",
 " with ",
 Cell[BoxData[
  ButtonBox["&&",
   BaseStyle->"Link",
   ButtonData->"And"]], "InlineCode"],
 ", ",
 Cell[BoxData[
  ButtonBox["||",
   BaseStyle->"Link",
   ButtonData->"Or"]], "InlineCode"],
 ", etc.?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "There\[CloseCurlyQuote]s an order of operations that\[CloseCurlyQuote]s a \
direct analog of arithmetic. ",
 Cell[BoxData[
  ButtonBox["&&",
   BaseStyle->"Link",
   ButtonData->"And"]], "InlineCode"],
 " is like ",
 Cell[BoxData[
  ButtonBox["\[Times]",
   BaseStyle->"Link",
   ButtonData->"Times"]], "InlineCode"],
 ", ",
 Cell[BoxData[
  ButtonBox["||",
   BaseStyle->"Link",
   ButtonData->"Or"]], "InlineCode"],
 " is like ",
 Cell[BoxData[
  ButtonBox["+",
   BaseStyle->"Link",
   ButtonData->"Plus"]], "InlineCode"],
 ", and ",
 Cell[BoxData[
  ButtonBox["!",
   BaseStyle->"Link",
   ButtonData->"Not"]], "InlineCode"],
 " is like ",
 Cell[BoxData[
  ButtonBox["\[Minus]",
   BaseStyle->"Link",
   ButtonData->"Subtract"]], "InlineCode"],
 ". So ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["!",
    BaseStyle->"Link",
    ButtonData->"Not"], "p", 
   ButtonBox["&&",
    BaseStyle->"Link",
    ButtonData->"And"], "q"}]], "InlineCode"],
 " means \[OpenCurlyDoubleQuote](not ",
 Cell[BoxData["p"], "InlineCode"],
 ") and ",
 Cell[BoxData["q"], "InlineCode"],
 "\[CloseCurlyDoubleQuote]; ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["!",
    BaseStyle->"Link",
    ButtonData->"Not"], 
   RowBox[{"(", 
    RowBox[{"p", 
     ButtonBox["&&",
      BaseStyle->"Link",
      ButtonData->"And"], "q"}], ")"}]}]], "InlineCode"],
 " means \[OpenCurlyDoubleQuote]not (",
 Cell[BoxData["p"], "InlineCode"],
 " and ",
 Cell[BoxData["q"], "InlineCode"],
 ")\[CloseCurlyDoubleQuote]. "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "What\[CloseCurlyQuote]s special about \[OpenCurlyDoubleQuote]",
 Cell[BoxData["Q"], "InlineCode"],
 "\[CloseCurlyDoubleQuote] functions?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "They ask a question that normally has an answer of ",
 ButtonBox["True",
  BaseStyle->"Link"],
 " or ",
 ButtonBox["False",
  BaseStyle->"Link"],
 ". "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["What are some other \[OpenCurlyDoubleQuote]Q\[CloseCurlyDoubleQuote] \
functions?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["NumberQ",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["StringContainsQ",
  BaseStyle->"Link"],
 ", ",
 ButtonBox["BusinessDayQ",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["ConnectedGraphQ",
  BaseStyle->"Link"],
 " are a few."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Is there a better way to find real-world entities with certain properties \
than using ",
 ButtonBox["Select",
  BaseStyle->"Link"],
 "?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Yes. You can do things like ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Entity",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"\"\<Country\>\"", ",", 
    RowBox[{"\"\<Population\>\"", "\[Rule]", 
     RowBox[{
      ButtonBox["GreaterThan",
       BaseStyle->"CodeLink"], "[", 
      TemplateBox[{
        SuperscriptBox["10", "7"], "\"people\"", "people", "\"People\""},
       "Quantity"], "]"}]}]}], "]"}]], "InlineCode"],
 " to find \[OpenCurlyDoubleQuote]implicit entities\[CloseCurlyDoubleQuote], \
then use ",
 ButtonBox["EntityList",
  BaseStyle->"Link"],
 " to get explicit lists of entities."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["True",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["False",
  BaseStyle->"Link"],
 " are typically called ",
 StyleBox["Booleans",
  FontSlant->"Italic"],
 " in computer science, after George Boole from the mid-1800s. Expressions \
with ",
 Cell[BoxData[
  ButtonBox["&&",
   BaseStyle->"Link",
   ButtonData->"And"]], "InlineCode"],
 ", ",
 Cell[BoxData[
  ButtonBox["||",
   BaseStyle->"Link",
   ButtonData->"Or"]], "InlineCode"],
 ", etc. are often called ",
 StyleBox["Boolean expressions",
  FontSlant->"Italic"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "In the Wolfram Language, ",
 ButtonBox["True",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["False",
  BaseStyle->"Link"],
 " are",
 StyleBox[" symbols",
  FontSlant->"Italic"],
 ", and are not represented by 1 and 0 as in many other computer languages."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["If",
  BaseStyle->"Link"],
 " is often called a ",
 StyleBox["conditional",
  FontSlant->"Italic"],
 ". In ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["If",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    StyleBox["test", "CodeVariable"], ",", 
    StyleBox["then", "CodeVariable"], ",", 
    StyleBox["else", "CodeVariable"]}], "]"}]], "InlineCode"],
 ", the ",
 Cell[BoxData[
  StyleBox["then", "CodeVariable"]], "InlineCode"],
 " and ",
 Cell[BoxData[
  StyleBox["else", "CodeVariable"]], "InlineCode"],
 " aren\[CloseCurlyQuote]t computed unless the ",
 Cell[BoxData[
  StyleBox["test", "CodeVariable"]], "InlineCode"],
 " says their condition is met."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 ButtonBox["PalindromeQ",
  BaseStyle->"Link"],
 " directly tests if a string is a palindrome."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "In the Wolfram Language, ",
 Cell[BoxData["x"], "InlineCode"],
 " is a ",
 StyleBox["symbol",
  FontSlant->"Italic"],
 " (see ",
 ButtonBox["Section 33",
  BaseStyle->"Hyperlink",
  ButtonData->{"EIWL3-33-expressions-and-their-structure.nb", None}],
 ") that could represent anything, so ",
 Cell[BoxData[
  RowBox[{"x", 
   ButtonBox["==",
    BaseStyle->"Link",
    ButtonData->"Equal"], "1"}]], "InlineCode"],
 " is just an ",
 StyleBox["equation",
  FontSlant->"Italic"],
 ", that isn\[CloseCurlyQuote]t immediately ",
 ButtonBox["True",
  BaseStyle->"Link"],
 " or ",
 ButtonBox["False",
  BaseStyle->"Link"],
 ". ",
 Cell[BoxData[
  RowBox[{"x", 
   ButtonBox["===",
    BaseStyle->"Link",
    ButtonData->"SameQ"], "1"}]], "InlineCode"],
 " (\[OpenCurlyDoubleQuote]triple equals\[CloseCurlyDoubleQuote]) tests \
whether ",
 Cell[BoxData["x"], "InlineCode"],
 " is ",
 StyleBox["the same",
  FontSlant->"Italic"],
 " as ",
 Cell[BoxData["1"], "InlineCode"],
 ", and since it isn\[CloseCurlyQuote]t, it gives ",
 ButtonBox["False",
  BaseStyle->"Link"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["More to Explore", "MoreExploreSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[ButtonBox["Guide to Functions That Apply Tests in the Wolfram \
Language\[NonBreakingSpace]\[RightGuillemet]",
 BaseStyle->"Link",
 ButtonData->"paclet:guide/TestingExpressions"]], "MoreExplore",
 Editable->False,
