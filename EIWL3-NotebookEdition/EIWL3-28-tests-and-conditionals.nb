Cell["\<\
Select letters that appear after position 10 in the alphabet:\
\>", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Select", "[", 
  RowBox[{
   RowBox[{"Characters", "[", "\"\<30 is the best!\>\"", "]"}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"LetterQ", "[", "#", "]"}], "&&", 
     RowBox[{
      RowBox[{"LetterNumber", "[", "#", "]"}], ">", "10"}]}], "&"}]}], 
