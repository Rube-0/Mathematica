 Deletable->False,
 CellLabel->"In[18]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "False", ",", "False", ",", "False", ",", "True", ",", "True", ",", "False",
    ",", "True", ",", "True", ",", "True", ",", "False", ",", "True", ",", 
   "True", ",", "True", ",", "True", ",", "False"}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[18]="]
}, Open  ]],

