         TemplateBox[{"\"Jupiter\"", 
           RowBox[{"Entity", "[", 
             RowBox[{"\"Planet\"", ",", "\"Jupiter\""}], "]"}], 
           "\"Entity[\\\"Planet\\\", \\\"Jupiter\\\"]\"", "\"planet\""},
