  ButtonBox["\[NotEqual]",
   BaseStyle->"Link",
   ButtonData->"Unequal"]], "InlineCodeText"],
 ", which is typed as ",
 Cell[BoxData["!="], "InlineCode"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "If an element is not equal to 4, make it ",
