      ButtonData->"Rule"], 
     StyleBox["rhs", "CodeVariableLrg"]}], " ", Cell[TextData[{
     "replace ",
     Cell[BoxData[
      StyleBox["lhs", "CodeVariable"]], "InlineCode"],
     " by ",
     Cell[BoxData[
      StyleBox["rhs", "CodeVariable"]], "InlineCode"],
     " in ",
     Cell[BoxData[
      StyleBox["expr", "CodeVariable"]], "InlineCode"]
    }], "VocabularyText"]}
  }]], "VocabularyTable",
