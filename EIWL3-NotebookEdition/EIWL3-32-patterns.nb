     BaseStyle->"CodeLink",
     ButtonData->"Blank"], " ", Cell[
    "pattern standing for anything (\[OpenCurlyDoubleQuote]blank\
\[CloseCurlyDoubleQuote]) ", "VocabularyText"]},
   {
    ButtonBox[
     RowBox[{"_", "\[ThinSpace]", "_"}],
     BaseStyle->"CodeLink",
