Cell[TextData[{
 "The form ",
 StyleBox["a",
  FontSlant->"Italic"],
 "\[Rule]",
 StyleBox["b",
  FontSlant->"Italic"],
 " is usually called a ",
 StyleBox["rule",
  FontSlant->"Italic"],
 ". If ",
 Cell[BoxData[
  RowBox[{"x", 
   ButtonBox["_",
    BaseStyle->"Link",
    ButtonData->"Blank"]}]], "InlineCodeText"],
 " appears on the left-hand side of a rule, then whatever the ",
 Cell[BoxData[
  RowBox[{"x", 
   ButtonBox["_",
    BaseStyle->"Link",
    ButtonData->"Blank"]}]], "InlineCodeText"],
 " matches can be referred to on the right-hand side as ",
 Cell[BoxData["x"], "InlineCodeText"],
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Use ",
 Cell[BoxData["x"], "InlineCode"],
 " in the right-hand side of the rule to refer to what ",
 Cell[BoxData[
  RowBox[{"x", 
   ButtonBox["_",
    BaseStyle->"Link",
    ButtonData->"Blank"]}]], "InlineCode"],
 " matches:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

