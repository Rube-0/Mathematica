Cell[TextData[{
 "But what if we want to make a table where the elements aren\
\[CloseCurlyQuote]t identical? We can do that by ",
 "introducing a ",
 StyleBox["variable",
  FontSlant->"Italic"],
 ", and then ",
 StyleBox["iterating",
  FontSlant->"Italic"],
 " over that variable",
 "."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{66, 10}, {7, 4}}],

Cell[TextData[{
 "Iterate over ",
 Cell[BoxData["n"], "InlineCode"],
 " to make a list where ",
 Cell[BoxData["n"], "InlineCode"],
 " goes up to 5:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{66, 10}, {4, 9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"a", "[", "n", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"n", ",", "5"}], "}"}]}], "]"}]], "Input",
 Deletable->False,
 CellLabel->"In[5]:="],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"a", "[", "1", "]"}], ",", 
   RowBox[{"a", "[", "2", "]"}], ",", 
   RowBox[{"a", "[", "3", "]"}], ",", 
   RowBox[{"a", "[", "4", "]"}], ",", 
   RowBox[{"a", "[", "5", "]"}]}], "}"}]], "Output",
 Editable->False,
 CellEditDuplicate->False,
 Evaluatable->False,
 CellLabel->"Out[5]="]
}, Open  ]],

Cell[TextData[{
 "Here\[CloseCurlyQuote]s how this works. To make the first element of the \
list, ",
 Cell[BoxData["n"], "InlineCodeText"],
 " is taken to be 1, so ",
 Cell[BoxData[
  RowBox[{"a", "[", "n", "]"}]], "InlineCodeText"],
 " is ",
 Cell[BoxData[
  RowBox[{"a", "[", "1", "]"}]], "InlineCodeText"],
 ". To make the second element, ",
 Cell[BoxData["n"], "InlineCodeText"],
 " is taken to be 2, so ",
 Cell[BoxData[
  RowBox[{"a", "[", "n", "]"}]], "InlineCodeText"],
 " is ",
 Cell[BoxData[
  RowBox[{"a", "[", "2", "]"}]], "InlineCodeText"],
 ", and so on. ",
 Cell[BoxData["n"], "InlineCodeText"],
 " is called a variable because it\[CloseCurlyQuote]s varying as we make the \
different elements of the list."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{66, 10}, {7, 4}}],

Cell[TextData[{
 "Make a table that gives the value of ",
