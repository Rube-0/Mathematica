Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{64, Inherited}, {8, 28}}],

Cell[TextData[{
 "What does the ",
 Cell[BoxData[
  RowBox[{"{", "\[ThinSpace]\[NegativeThinSpace]", 
   StyleBox["...",
    FontColor->GrayLevel[0.6]], "}"}]], "InlineCode"],
 " (list) in ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Table",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{"n", "^", "2"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "5"}], "}"}]}], "]"}]], "InlineCode"],
 " mean?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "A list is always a way of collecting things together. Here what it\
\[CloseCurlyQuote]s collecting is the variable ",
 Cell[BoxData["n"], "InlineCode"],
 " and its range 5. In the Wolfram Language, this kind of use of a list is \
called an ",
 StyleBox["iterator specification",
  FontSlant->"Italic"],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Why is the ",
 Cell[BoxData[
  RowBox[{"{", "\[ThinSpace]\[NegativeThinSpace]", 
   StyleBox["...",
    FontColor->GrayLevel[0.6]], "}"}]], "InlineCode"],
 " (list) in ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Table",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{"n", "^", "2"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "5"}], "}"}]}], "]"}]], "InlineCode"],
 " needed?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 9}}],

Cell[TextData[{
 "So one can easily generalize to multidimensional arrays, like ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Table",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{
     RowBox[{"x", "^", "2"}], "-", 
     RowBox[{"y", "^", "2"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "5"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "5"}], "}"}]}], "]"}]], "InlineCode"],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["What are the constraints on the names of variables?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 7}}],

Cell["\<\
They can be any sequence of letters or numbers, but they \
can\[CloseCurlyQuote]t start with a number, and\[LongDash]to avoid possible \
confusion with built-in Wolfram Language functions\[LongDash]they shouldn\
\[CloseCurlyQuote]t start with a capital letter.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell["\<\
Why do you have to name a variable if the name never matters?\
\>", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 10}}],

Cell[TextData[{
 "Good question! In ",
 ButtonBox["Section 26",
  BaseStyle->"Hyperlink",
  ButtonData->{"EIWL3-26-pure-anonymous-functions.nb", None}],
 ", we\[CloseCurlyQuote]ll see how to avoid having named variables. It\
\[CloseCurlyQuote]s very elegant, but it\[CloseCurlyQuote]s a little more \
abstract than what we\[CloseCurlyQuote]re doing with ",
 ButtonBox["Table",
  BaseStyle->"Link"],
 " here. "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Can ",
 ButtonBox["Range",
  BaseStyle->"Link"],
 " deal with negative numbers?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{65, Inherited}, {2, 10}}],

Cell[TextData[{
 "Yes. ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Range",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{"-", "2"}], ",", "2"}], "]"}]], "InlineCode"],
 " gives ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"-", "2"}], ",", 
    RowBox[{"-", "1"}], ",", "0", ",", "1", ",", "2"}], "}"}]], 
  "InlineCode"],
 ". ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Range",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"2", ",", 
    RowBox[{"-", "2"}]}], "]"}]], "InlineCode"],
 " gives ",
 Cell[BoxData[
  RowBox[{"{", "}"}]], "InlineCode"],
 ", but ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Range",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"2", ",", 
    RowBox[{"-", "2"}], ",", 
    RowBox[{"-", "1"}]}], "]"}]], "InlineCode"],
 " gives ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"2", ",", "1", ",", "0", ",", 
    RowBox[{"-", "1"}], ",", 
    RowBox[{"-", "2"}]}], "}"}]], "InlineCode"],
 "."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellMargins->{{64, Inherited}, {8, 28}}],

Cell[TextData[{
 "If you specify steps that don\[CloseCurlyQuote]t fit evenly in the range \
you give, ",
 ButtonBox["Range",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["Table",
  BaseStyle->"Link"],
 " just go as far as the steps take them, potentially stopping before the \
upper limit. (So ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Range",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{"1", ",", "6", ",", "2"}], "]"}]], "InlineCode"],
 " gives ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1", ",", "3", ",", "5"}], "}"}]], "InlineCode"],
 ", stopping at 5, not 6.)"
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["Table",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{"f", "[", "n", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["v", "CodeVariable"], 
         StyleBox["1", "TR"]], ",", 
        SubscriptBox[
         StyleBox["v", "CodeVariable"], 
         StyleBox["2", "TR"]], ",", 
        RowBox[{
         SubscriptBox[
          StyleBox["v", "CodeVariable"], 
          StyleBox["3", "TR"]], 
         StyleBox["...",
          FontColor->GrayLevel[0.6]]}]}], "}"}]}], "}"}]}], "]"}]], 
  "InlineCode"],
 " lets you make a table using whatever values of ",
 Cell[BoxData["n"], "InlineCode"],
 " you want; here you would get ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"f", "[", 
     SubscriptBox[
      StyleBox["v", "CodeVariable"], 
      StyleBox["1", "TR"]], "]"}], ",", 
    RowBox[{"f", "[", 
     SubscriptBox[
      StyleBox["v", "CodeVariable"], 
      StyleBox["2", "TR"]], "]"}], ",", 
    RowBox[{"f", "[", 
     SubscriptBox[
      StyleBox["v", "CodeVariable"], 
      StyleBox["3", "TR"]], "]"}], ",", 
    StyleBox["...",
     FontColor->GrayLevel[0.6]]}], "}"}]], "InlineCode"],
 ". In ",
 ButtonBox["Section 25",
  BaseStyle->"Hyperlink",
  ButtonData->{"EIWL3-25-ways-to-apply-functions.nb", None}],
 ", we\[CloseCurlyQuote]ll see how to get the same result with ",
 ButtonBox["Map",
  BaseStyle->"Link"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False]
}, Open  ]],

