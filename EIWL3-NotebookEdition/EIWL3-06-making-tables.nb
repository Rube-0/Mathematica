Cell[TextData[{
 "In ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Table",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{"f", "[", "n", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "5"}], "}"}]}], "]"}]], "InlineCodeText"],
 ", ",
 Cell[BoxData["n"], "InlineCodeText"],
 " takes on values 1, 2, 3, 4, 5. ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Table",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    RowBox[{"f", "[", "n", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"n", ",", "3", ",", "5"}], "}"}]}], "]"}]], "InlineCodeText"],
 " says to start at 3 instead: 3, 4, 5."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

