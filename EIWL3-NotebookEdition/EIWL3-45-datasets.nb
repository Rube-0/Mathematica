    BaseStyle->"Link",
    ButtonData->"Composition"], "g", 
   ButtonBox["@*",
    BaseStyle->"Link",
    ButtonData->"Composition"], "h"}]], "InlineCode",ExpressionUUID->
  "38af7882-da93-44d5-9b6a-5aa3229572b6"],
