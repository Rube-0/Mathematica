Cell["\<\
As a final example, let\[CloseCurlyQuote]s make a word cloud of names of \
moons, sized according to the masses of the moons. To do this, we need a \
single association that associates the name of each moon with its mass. \
\>", "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"ec4bf51c-c960-4aed-a009-4069ce407954"],

Cell[TextData[{
 "When given an association, ",
 ButtonBox["WordCloud",
  BaseStyle->"Link"],
 " determines sizes from values in the association:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"f1328993-3e77-4cd1-bc75-ebcb8d277ef0"],

