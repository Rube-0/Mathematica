Cell[BoxData[
 RowBox[{"WordCloud", "[", 
  RowBox[{"\[LeftAssociation]", 
   RowBox[{
    RowBox[{"\"\<A\>\"", "\[Rule]", "5"}], ",", 
    RowBox[{"\"\<B\>\"", "\[Rule]", "4"}], ",", 
    RowBox[{"\"\<C\>\"", "\[Rule]", "3"}], ",", 
    RowBox[{"\"\<D\>\"", "\[Rule]", "2"}], ",", 
    RowBox[{"\"\<E\>\"", "\[Rule]", "1"}]}], "\[RightAssociation]"}], 
  "]"}]], "Input",
