Cell[CellGroupData[{

Cell["Q&A", "QASection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"362797bb-693e-4c56-beaa-678b582cece9"],

Cell["What kinds of data can datasets contain?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"759bff6e-9c4f-495f-a09a-63977abeaad9"],

Cell["\<\
Any kinds. Not just numbers and text but also images, graphs and lots more. \
There\[CloseCurlyQuote]s no need for all elements of a particular row or \
column to be the same type.\
\>", "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"8f8d9cdb-c15f-4857-b22b-0186009b6530"],

Cell["Can I adjust the formatting of datasets?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"be0fe5e9-eb80-4b8d-8b9b-4d57d25d11cd"],

Cell[TextData[{
 "Yes. There are many options. For example, ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["Dataset",
    BaseStyle->"CodeLink"], "[", 
   RowBox[{
    StyleBox["dataset", "CodeVariable"], ",", 
    StyleBox[" ", "CodeVariable"], 
    RowBox[{
     ButtonBox["MaxItems",
      BaseStyle->"CodeLink"], " ", "\[RightArrow]", " ", "5"}]}], "]"}]], 
  "InlineCode",ExpressionUUID->"3dece0da-e665-4c5f-aa21-b607cdb77fd2"],
 " will display 5 items per \[OpenCurlyDoubleQuote]page\
\[CloseCurlyDoubleQuote]."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"84195694-9142-4ce6-bb3d-b74f4b10f66b"],

Cell["Can I turn spreadsheets into datasets?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"d98e0d1b-c0a5-458e-9121-36d20199307b"],

Cell[TextData[{
 "Yes. ",
 ButtonBox["SemanticImport",
  BaseStyle->"Link"],
 " is often a good way to do it. "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"9b6dc786-7d18-4286-9a85-558dec97c67c"],

Cell[TextData[{
 "What are databases and how do they relate to ",
 ButtonBox["Dataset",
  BaseStyle->"Link"],
 "?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"d2ff23f8-4167-4f88-a422-4c9cea81e268"],

Cell[TextData[{
 "Databases are a traditional way to store structured data in a computer \
system. Databases are often set up to allow both reading and writing of data. \
",
 ButtonBox["Dataset",
  BaseStyle->"Link"],
 " is a way to represent data that might be stored in a database so that it\
\[CloseCurlyQuote]s easy to manipulate with the Wolfram Language. "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"75cd4319-f985-4fd2-a877-6eec3ce41ba5"],

Cell[TextData[{
 "How does data in ",
 ButtonBox["Dataset",
  BaseStyle->"Link"],
 " compare to data in an SQL (relational) database?"
}], "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"fa4f729c-186b-4e32-b406-92de97704fb2"],

Cell[TextData[{
 "SQL databases are strictly based on tables of data arranged in rows and \
columns of particular types, with additional data linked in through \
\[OpenCurlyDoubleQuote]foreign keys\[CloseCurlyDoubleQuote]. ",
 ButtonBox["Dataset",
  BaseStyle->"Link"],
 " can have any mixture of types of data, with any number of levels of \
nesting, and any hierarchical structure, somewhat more analogous to a NoSQL \
database, but with additional operations made possible by the symbolic nature \
of the language. "
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"feedb281-15a0-4ac3-b2ff-7e670d73ae50"],

Cell["Can I use datasets to set up entities and values for them?", "Question",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"0a3b03c5-df0b-4e43-ac48-1744f31ca4e4"],

Cell[TextData[{
 "Yes. If you\[CloseCurlyQuote]ve got a dataset that\[CloseCurlyQuote]s an \
association of associations, with the outer keys being entities and the inner \
ones being properties, then you just have to put this inside ",
 ButtonBox["EntityStore",
  BaseStyle->"Link"],
 ", and you\[CloseCurlyQuote]ll pretty much have everything set up."
}], "Answer",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->
  "LastCellOfAPage",ExpressionUUID->"c861b402-bd2a-4740-8544-ae36cc2705ec"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Tech Notes", "TechNoteSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False,
 CellTags->"p: 304",ExpressionUUID->"c60b5113-1d8f-4fdc-bd89-7783492efc58"],

Cell[TextData[{
 ButtonBox["Dataset",
  BaseStyle->"Link"],
 " supports a new kind of ",
 StyleBox["symbolic database structure",
  FontSlant->"Italic"],
 " which generalizes both ",
 StyleBox["relational",
  FontSlant->"Italic"],
 " and ",
 StyleBox["hierarchical databases",
  FontSlant->"Italic"],
 "."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"8262dfc3-7948-4f2f-bb2f-0afb626d966c"],

Cell[TextData[{
 ButtonBox["Dataset",
  BaseStyle->"Link"],
 " has many additional mechanisms and capabilities that we haven\
\[CloseCurlyQuote]t discussed."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"ffdb9fc2-e436-48cf-ad41-82d71d766a23"],

Cell[TextData[{
 "Everything that can be done with queries on datasets can also be done by \
using functions like ",
 ButtonBox["Map",
  BaseStyle->"Link"],
 " and ",
 ButtonBox["Apply",
  BaseStyle->"Link"],
 " on underlying lists and association\[LongDash]but it\[CloseCurlyQuote]s \
typically much simpler with dataset queries."
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"e2aa90d6-ce09-4aba-9795-75984f0c90f5"],

Cell[TextData[{
 "You can connect the Wolfram Language directly to SQL \
databases\[LongDash]and do queries with SQL syntax\[LongDash]using ",
 ButtonBox["DatabaseLink",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://reference.wolfram.com/language/DatabaseLink/guide/\
SQLDatabaseOperations.html"], None},
  ButtonNote->
   "http://reference.wolfram.com/language/DatabaseLink/guide/\
SQLDatabaseOperations.html"],
 ". "
}], "TechNote",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"38d0ba68-f483-4934-8aac-3e038ef0f201"]
}, Open  ]],

Cell[CellGroupData[{

Cell["More to Explore", "MoreExploreSection",
 Editable->False,
 Deletable->False,
 ShowCellBracket->
  False,ExpressionUUID->"a39a2e21-badb-4de5-8c85-78bf97e3cee5"],

