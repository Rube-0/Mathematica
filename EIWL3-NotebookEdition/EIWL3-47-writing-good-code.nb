Cell[TextData[{
 "The algorithm we used happens to do an exponential amount of unnecessary \
work recomputing what it\[CloseCurlyQuote]s already computed before. We can \
avoid this by making the definition for ",
 Cell[BoxData[
  RowBox[{"fib", "[", "n_", "]"}]], "InlineCodeText"],
 " always do an assignment for ",
 Cell[BoxData[
  RowBox[{"fib", "[", "n", "]"}]], "InlineCodeText"],
 ", so it stores the result of each intermediate computation."
}], "Text",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[TextData[{
 "Redefine the ",
 Cell[BoxData["fib"], "InlineCode"],
 " function to remember every value it computes:"
}], "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"fib", "[", "1", "]"}], "=", 
   RowBox[{
    RowBox[{"fib", "[", "2", "]"}], "=", "1"}]}], ";"}]], "Input", \
"Reevaluate",
 CellLabel->"In[26]:="],

Cell[BoxData[
 RowBox[{
  RowBox[{"fib", "[", "n_Integer", "]"}], ":=", 
  RowBox[{
   RowBox[{"fib", "[", "n", "]"}], "=", 
   RowBox[{
    RowBox[{"fib", "[", 
     RowBox[{"n", "-", "1"}], "]"}], "+", 
    RowBox[{"fib", "[", 
     RowBox[{"n", "-", "2"}], "]"}]}]}]}]], "Input", "Reevaluate",
 CellLabel->"In[27]:="],

Cell["\<\
Now even up to 1000 each new value takes only microseconds to compute:\
\>", "CodeCaption",
 Editable->False,
 Deletable->False,
 ShowCellBracket->False],

