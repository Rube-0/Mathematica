times \:7684\:7f3a\:7701\:503c\:4e3a7.\
\>", "Text",
 CellChangeTimes->{{3.691968216005734*^9, 3.691968359042459*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"hangmanable", ",", "Listable"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hangmanable", "[", 
   RowBox[{"x_String", ",", 
    RowBox[{"times_Integer:", "7"}]}], "]"}], ":=", "\[IndentingNewLine]", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "tw", ",", "truelist", ",", "ntruelist", ",", "hangman", ",", "words", 
      ",", "cs"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tw", "=", "x"}], ";", "\[IndentingNewLine]", 
     RowBox[{"truelist", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ntruelist", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"cs", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"words", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"TrueQ", "[", 
        RowBox[{
         RowBox[{"Length", "@", "ntruelist"}], "<", "times"}], "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"hangman", "=", 
         RowBox[{"StringReplace", "[", 
          RowBox[{"tw", ",", 
           RowBox[{
            RowBox[{"RegularExpression", "[", 
             RowBox[{"\"\<[^ \>\"", "<>", 
              RowBox[{"StringJoin", "@@", 
               RowBox[{"ToLowerCase", "@", "truelist"}]}], "<>", 
              RowBox[{"StringJoin", "@@", 
               RowBox[{"ToUpperCase", "@", "truelist"}]}], "<>", 
              "\"\<]\>\""}], "]"}], "\[RuleDelayed]", "\"\<.\>\""}]}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"words", "=", 
         RowBox[{"DictionaryLookup", "[", 
          RowBox[{
           RowBox[{"RegularExpression", "[", 
            RowBox[{"StringReplace", "[", 
             RowBox[{"hangman", ",", "\[IndentingNewLine]", 
              RowBox[{"\"\<.\>\"", "\[Rule]", " ", 
               RowBox[{"\"\<[^ \>\"", "<>", 
                RowBox[{"StringJoin", "@@", "truelist"}], "<>", 
                RowBox[{"StringJoin", "@@", "ntruelist"}], "<>", 
                "\"\<]\>\""}]}]}], "]"}], "]"}], ",", 
           RowBox[{"IgnoreCase", "\[Rule]", "True"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"cs", "=", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"Sort", "[", 
            RowBox[{
             RowBox[{"Complement", "[", 
              RowBox[{
               RowBox[{"CharacterRange", "[", 
                RowBox[{"\"\<a\>\"", ",", "\"\<z\>\""}], "]"}], ",", 
               RowBox[{"ToLowerCase", "@", "truelist"}]}], "]"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"Total", "@", 
                RowBox[{"Boole", "@", 
                 RowBox[{"StringContainsQ", "[", 
                  RowBox[{"words", ",", "#1", ",", 
                   RowBox[{"IgnoreCase", "\[Rule]", "True"}]}], "]"}]}]}], 
               ">", 
               RowBox[{"Total", "@", 
                RowBox[{"Boole", "@", 
                 RowBox[{"StringContainsQ", "[", 
                  RowBox[{"words", ",", "#2", ",", 
                   RowBox[{"IgnoreCase", "\[Rule]", "True"}]}], "]"}]}]}]}], 
              "&"}]}], "]"}], ",", 
           RowBox[{
            RowBox[{"ContainsAll", "[", 
             RowBox[{
              RowBox[{"ToLowerCase", "@", 
               RowBox[{"DeleteDuplicates", "@", 
                RowBox[{"Flatten", "@", 
                 RowBox[{"Characters", "@", "words"}]}]}]}], ",", 
              RowBox[{"{", "#", "}"}]}], "]"}], "&"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Length", "@", "cs"}], "\[LessEqual]", "1"}], "||", 
           RowBox[{
            RowBox[{"Length", "@", "words"}], "\[LessEqual]", "1"}]}], ",", 
          RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"StringContainsQ", "[", 
           RowBox[{"tw", ",", 
            RowBox[{
            "cs", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",", 
            RowBox[{"IgnoreCase", "\[Rule]", "True"}]}], "]"}], ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"truelist", ",", 
            RowBox[{
            "cs", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
           "]"}], ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"ntruelist", ",", 
            RowBox[{
            "cs", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
           "]"}]}], "]"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Boole", "[", 
      RowBox[{
       RowBox[{"StringContainsQ", "[", 
        RowBox[{
         RowBox[{
         "words", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",",
          "tw", ",", 
         RowBox[{"IgnoreCase", "\[Rule]", "True"}]}], "]"}], "&&", 
       RowBox[{
        RowBox[{"Length", "@", "words"}], "\[Equal]", "1"}]}], "]"}]}]}], 
   "]"}]}], "\[IndentingNewLine]"}], "Input",
