     RowBox[{"l10", "=", ".5"}], ",", 
     RowBox[{"v0", "=", "0"}], ",", "AM1", ",", "AM2", ",", "moment1", ",", 
     "moment2", ",", "pos1", ",", "pos2", ",", "eqns", ",", "sol"}], "}"}], 
   ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"AM1", "[", "t_", "]"}], ":=", 
     RowBox[{"M", " ", 
      RowBox[{
       RowBox[{"l1", "[", "t", "]"}], "^", "2"}], " ", 
      RowBox[{
       RowBox[{"\[Theta]1", "'"}], "[", "t", "]"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"AM2", "[", "t_", "]"}], ":=", 
     RowBox[{"m", " ", 
