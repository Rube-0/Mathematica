Cell[BoxData[{
 RowBox[{"ClearAll", "[", "fib", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fib", "[", 
   RowBox[{"n_", "?", "OddQ"}], "]"}], ":=", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"fib", "[", 
     FractionBox[
      RowBox[{"n", "+", "1"}], "2"], "]"}], "2"], "+", 
   SuperscriptBox[
    RowBox[{"fib", "[", 
     FractionBox[
      RowBox[{"n", "-", "1"}], "2"], "]"}], "2"]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fib", "[", 
   RowBox[{"n_", "?", "EvenQ"}], "]"}], ":=", 
  RowBox[{
