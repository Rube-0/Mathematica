Cell[BoxData[{
 RowBox[{"ClearAll", "@", "insertsort"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"insertsort", "[", "data_List", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"arr", "=", "data"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"arr", "[", 
            RowBox[{"[", "j", "]"}], "]"}], "\[GreaterEqual]", 
           RowBox[{"arr", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"arr", "=", 
            RowBox[{"Insert", "[", 
             RowBox[{"arr", ",", 
              RowBox[{"arr", "[", 
               RowBox[{"[", "i", "]"}], "]"}], ",", "j"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"arr", "=", 
            RowBox[{"Delete", "[", 
             RowBox[{"arr", ",", 
              RowBox[{"i", "+", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
           
           RowBox[{"Sow", "@", "arr"}], ";", "\[IndentingNewLine]", 
           "Break"}]}], "\[IndentingNewLine]", "]"}], ";"}], 
       "\[IndentingNewLine]", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "@", "data"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", 
         RowBox[{"i", "-", "1"}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "arr"}]}], "\[IndentingNewLine]", 
