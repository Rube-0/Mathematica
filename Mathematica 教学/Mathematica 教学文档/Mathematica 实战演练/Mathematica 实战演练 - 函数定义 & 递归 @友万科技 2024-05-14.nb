  RowBox[{
   SuperscriptBox[
    RowBox[{"fib", "[", 
     FractionBox[
      RowBox[{"n", "+", "1"}], "2"], "]"}], "2"], "+", 
   SuperscriptBox[
    RowBox[{"fib", "[", 
