Cell[CellGroupData[{

Cell["", "DetailsSection",ExpressionUUID->"bbe9fa39-956b-4c09-8683-becfaf943b14"],

Cell["\<\
Snapshot 1: above the threshold wavelength, there is no emission of \
photoelectrons, no matter how high the radiation intensity\
\>", "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.414269693705415*^9, 3.414269714116776*^9}, {
   3.414270156055745*^9, 3.414270209786954*^9}, {3.414521636984572*^9, 
   3.4145216383439384`*^9}},
 CellID->1388305653,ExpressionUUID->"31cf5eca-63b0-42dd-918e-845ba56c00b2"],

Cell["\<\
Snapshot 2: at the threshold wavelength for Ag, around 290 nm, the \
photoelectric effect occurs\
\>", "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, 3.414270227622731*^9, {3.414271542223794*^9, 
   3.4142716351782503`*^9}, {3.414521642937659*^9, 3.4145216466563854`*^9}},
 CellID->843285316,ExpressionUUID->"d5a65b46-0fad-4471-adbc-8df601a2cac5"],

Cell["\<\
Snapshot 3: once the threshold is reached, the electron current increases \
linearly with radiation intensity\
\>", "DetailNotes",
 CellChangeTimes->{
  3.35696210375764*^9, {3.41427168184492*^9, 3.414271723905246*^9}, {
   3.4145216410782957`*^9, 3.4145216495626163`*^9}},
 CellID->1851719459,ExpressionUUID->"c3e36e70-1dc8-4bea-921c-c1a4997d3ac9"]
}, Open  ]],

